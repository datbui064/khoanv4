    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@media (min-width: 769px) {
        .dropdown-hover:hover > .dropdown-menu

    {
        display: block;
        animation: fadeIn 0.2s ease-in-out;
    }

    .custom-dropdown {
