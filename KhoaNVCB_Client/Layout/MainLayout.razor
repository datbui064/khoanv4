@code {
    private List<CategoryDto>? categories;
    private bool isMobileMenuOpen = false;

    protected override async Task OnInitializedAsync()
    {
        try { categories = await CategoryService.GetAllAsync(); }
        catch { categories = new List<CategoryDto>(); }

        chatMessages.Add(new CustomChatMessage { IsUser = false, HtmlContent = "Xin chào! Tôi là trợ lý ảo của Khoa AN NINH CHÍNH TRỊ NỘI BỘ. Bạn cần hỗ trợ thông tin gì không?" });
    }

    private void ToggleMobileMenu() { isMobileMenuOpen = !isMobileMenuOpen; }
    private void CloseMobileMenu() { isMobileMenuOpen = false; }
    private async Task HandleLogout()
    {
        await AuthService.Logout();
        isMobileMenuOpen = false;
        Nav.NavigateTo("/", forceLoad: true);
    }

    // ==========================================
    // LOGIC CHATBOT AI
    // ==========================================
    public class CustomChatMessage
    {
        public bool IsUser { get; set; }
        public string HtmlContent { get; set; } = "";
    }

    private class ChatAskResponse { public string Answer { get; set; } = ""; }

    private bool isChatOpen = false;
    private List<CustomChatMessage> chatMessages = new();
    private string currentInput = "";
    private bool isBotTyping = false;

    private bool isSupportFormOpen = false;
    private bool isSubmittingTicket = false;
    private string supportName = "";
    private string supportContact = "";
    private string supportQuestion = "";

    private void ToggleChat()
    {
        isChatOpen = !isChatOpen;
        if (!isChatOpen) isSupportFormOpen = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentInput)) return;

        string userText = currentInput;
        currentInput = "";

        chatMessages.Add(new CustomChatMessage { IsUser = true, HtmlContent = userText });
        isBotTyping = true;
        StateHasChanged();

        try
        {
            var req = new { Message = userText, Context = "" };
            var res = await Http.PostAsJsonAsync("api/chatbot/ask", req);

            if (res.IsSuccessStatusCode)
            {
                var data = await res.Content.ReadFromJsonAsync<ChatAskResponse>();
                chatMessages.Add(new CustomChatMessage { IsUser = false, HtmlContent = data?.Answer ?? "Lỗi không đọc được dữ liệu." });
            }
            else
            {
                chatMessages.Add(new CustomChatMessage { IsUser = false, HtmlContent = "Xin lỗi, đường truyền đến AI đang gặp sự cố." });
            }
        }
        catch (Exception ex)
        {
            chatMessages.Add(new CustomChatMessage { IsUser = false, HtmlContent = $"Lỗi kết nối mạng: {ex.Message}" });
        }

        chatMessages.Add(new CustomChatMessage
            {
                IsUser = false,
                HtmlContent = "Câu trả lời này có giúp ích cho bạn không? <br/> <button class='btn btn-sm btn-outline-danger mt-2 fw-bold w-100' onclick='document.getElementById(\"btnTriggerSupport\").click()'>Phản hồi cho Admin</button>"
            });

        isBotTyping = false;
        StateHasChanged();
    }

    private async Task SubmitSupportTicket()
    {
        if (string.IsNullOrWhiteSpace(supportName) || string.IsNullOrWhiteSpace(supportContact) || string.IsNullOrWhiteSpace(supportQuestion))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng nhập đủ Họ tên, Liên lạc và Câu hỏi!");
            return;
        }

        isSubmittingTicket = true;
        StateHasChanged();

        try
        {
            var ticket = new { FullName = supportName, ContactInfo = supportContact, Question = supportQuestion };
            var res = await Http.PostAsJsonAsync("api/chatbot/ticket", ticket);

            if (res.IsSuccessStatusCode)
            {
                isSupportFormOpen = false;
                supportQuestion = "";

                chatMessages.Add(new CustomChatMessage
                    {
                        IsUser = false,
                        HtmlContent = $"✅ <strong>Đã gửi thành công!</strong><br/>Admin sẽ liên hệ lại với bạn qua: {supportContact}."
                    });
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Hệ thống đang bận, không thể gửi phiếu hỗ trợ lúc này.");
            }
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "Lỗi kết nối máy chủ!");
        }

        isSubmittingTicket = false;
        StateHasChanged();
    }
}

<button id="btnTriggerSupport" class="d-none" @onclick="() => { isSupportFormOpen = true; StateHasChanged(); }"></button>

<style>
