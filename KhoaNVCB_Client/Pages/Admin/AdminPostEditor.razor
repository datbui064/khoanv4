@page "/admin/posts/create"
@page "/admin/posts/edit/{id:int}"

@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS
@implements IDisposable
@inject PostService PostService
@inject CategoryService CategoryService
@inject PhotoUploadService PhotoUploadService
@inject NavigationManager Nav
@attribute [Authorize(Roles = "Admin")]

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-uppercase fw-bold border-start border-danger border-4 ps-2 m-0" style="color: #2c3e50;">
        @(id > 0 ? "Chỉnh sửa bài viết" : "Soạn thảo nội dung mới")
    </h3>
    <div class="text-end">
        <button class="btn btn-outline-secondary me-2 px-4 fw-bold" @onclick='() => Nav.NavigateTo("/admin/posts")'>HỦY</button>
        <button class="btn btn-danger px-5 fw-bold shadow-sm" @onclick="HandleSave" disabled="@isSubmitting">
            <i class="oi oi-check me-1"></i> @(isSubmitting ? "ĐANG XỬ LÝ..." : (id > 0 ? "CẬP NHẬT" : "ĐĂNG BÀI"))
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger shadow-sm py-2">
        <i class="oi oi-warning me-2"></i> @errorMessage
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
}
else
{
    @* 2. TIÊU ĐỀ *@
    <div class="mb-3">
        <label class="form-label fw-bold">Tiêu đề bài viết <span class="text-danger">*</span></label>
        <input class="form-control form-control-lg fw-bold text-dark" @bind="post.Title" placeholder="Nhập tiêu đề tại đây..." />
    </div>

    @* 3. THÔNG TIN PHÂN LOẠI & ẢNH BÌA *@
    <div class="row bg-light p-3 rounded-2 mx-0 mb-3 border">
        <div class="col-md-3 mb-3">
            <label class="form-label fw-bold">Chuyên mục <span class="text-danger">*</span></label>
            <select class="form-select" @bind="post.CategoryId">
                <option value="0">-- Chọn chuyên mục --</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                }
            </select>
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label fw-bold">Loại nội dung <span class="text-danger">*</span></label>
            <select class="form-select border-primary" @bind="post.SourceType">
                <option value="Image">Tin tức (Bài viết kèm ảnh)</option>
                <option value="Video">Video (Clip/YouTube)</option>
                <option value="Law">Quy định Pháp luật (PDF/Word)</option>
                <option value="Document">Văn bản liên quan (PDF/Word)</option>
                <option value="Propaganda">Tuyên truyền (Clip/Youtube)</option>
            </select>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Ảnh bìa (Thumbnail)</label>
            <InputFile OnChange="HandleImageCoverUpload" class="form-control" accept="image/*" />
            @if (isUploadingImage)
            {
                <div class="text-primary small mt-1"><i class="spinner-border spinner-border-sm"></i> Đang tải ảnh...</div>
            }
            @if (!string.IsNullOrEmpty(post.ImageUrl))
            {
                <div class="mt-2 text-center">
                    <img src="@post.ImageUrl" class="rounded shadow-sm" style="max-height: 120px; object-fit: contain;" />
                </div>
            }
        </div>
    </div>

    @* 4. PHẦN MỞ RỘNG THEO LOẠI NỘI DUNG *@
    @if (post.SourceType == "Video" || post.SourceType == "Propaganda")
    {
        <div class="mb-4 p-3 bg-white border border-danger rounded-2 shadow-sm" style="border-left-width: 5px !important;">
            <label class="form-label fw-bold text-danger"><i class="oi oi-video"></i> Link YouTube</label>
            <input class="form-control" @bind="post.OriginalUrl" placeholder="https://www.youtube.com/watch?v=..." />
            <small class="text-muted">Dán link YouTube để hệ thống tự nhúng video vào bài giảng.</small>
        </div>
    }
    else if (post.SourceType == "Law" || post.SourceType == "Document")
    {
        <div class="mb-4 p-3 bg-white border border-info rounded-2 shadow-sm" style="border-left-width: 5px !important;">
            <label class="form-label fw-bold text-info"><i class="oi oi-paperclip"></i> Đính kèm tệp tài liệu (PDF, DOCX)</label>
            <InputFile OnChange="HandleWordUpload" class="form-control" accept=".pdf,.docx" />

            @if (isUploadingFile)
            {
                <div class="text-info small mt-1"><span class="spinner-border spinner-border-sm"></span> Đang tải tệp lên server...</div>
            }
            @if (isParsingWord)
            {
                <div class="text-warning small mt-1"><span class="spinner-border spinner-border-sm"></span> Đang trích xuất nội dung văn bản...</div>
            }

            @if (!string.IsNullOrEmpty(post.OriginalUrl))
            {
                <div class="mt-2 p-2 bg-light rounded border d-flex justify-content-between align-items-center">
                    <span class="small text-truncate me-2">📎 File hiện tại: <strong>@GetFileName(post.OriginalUrl)</strong></span>
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick='() => post.OriginalUrl = ""'>Gỡ bỏ</button>
                </div>
            }
        </div>
    }

    @* 5. TÓM TẮT VÀ NỘI DUNG CHÍNH *@
    <div class="mb-3">
        <label class="form-label fw-bold">Mô tả ngắn (Summary)</label>
        <textarea class="form-control" rows="2" @bind="post.Summary" placeholder="Mô tả tóm tắt nội dung bài viết..."></textarea>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Nội dung chi tiết <span class="text-danger">*</span></label>
        <div id="tiny-editor"></div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }

    private PostDto post = new() { SourceType = "Image", Status = "Published" };
    private List<CategoryDto> categories = new();

    private string? errorMessage;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isParsingWord = false;
    private bool isUploadingImage = false;
    private bool isUploadingFile = false;
    private bool isEditorInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await CategoryService.GetAllAsync();
            if (id > 0)
            {
                var res = await PostService.GetByIdAsync(id);
                if (res != null) post = res;
                else errorMessage = "Không tìm thấy nội dung.";
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetFileName(string url) => string.IsNullOrEmpty(url) ? "" : System.IO.Path.GetFileName(url);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !isEditorInitialized)
        {
            isEditorInitialized = true;
            await JS.InvokeVoidAsync("initTinyMCE", DotNetObjectReference.Create(this), post.Content ?? "");
        }
    }

    [JSInvokable]
    public void UpdateContentFromJS(string content) => post.Content = content;

    private async Task HandleImageCoverUpload(InputFileChangeEventArgs e)
    {
        isUploadingImage = true;
        try
        {
            var url = await PhotoUploadService.UploadPhotoAsync(e.File);
            if (!string.IsNullOrEmpty(url)) post.ImageUrl = url;
        }
        catch (Exception ex) { errorMessage = "Lỗi tải ảnh: " + ex.Message; }
        finally { isUploadingImage = false; }
    }

    private async Task HandleWordUpload(InputFileChangeEventArgs e)
    {
        isUploadingFile = true;
        errorMessage = null;

        try
        {
            // 1. Upload file gốc để lưu link (Cho người dùng tải về sau này)
            var fileUrl = await PhotoUploadService.UploadPhotoAsync(e.File);
            if (!string.IsNullOrEmpty(fileUrl))
            {
                post.OriginalUrl = fileUrl;
            }

            // 2. Trích xuất text (Hỗ trợ .docx và .pdf dựa trên API của bạn)
            var ext = Path.GetExtension(e.File.Name).ToLower();
            if (ext == ".docx" || ext == ".pdf")
            {
                isParsingWord = true;
                StateHasChanged();

                var extractedHtml = await PostService.ExtractWordAsync(e.File);
                if (!string.IsNullOrEmpty(extractedHtml))
                {
                    post.Content = extractedHtml;
                    // Đẩy nội dung vào TinyMCE ngay lập tức
                    await JS.InvokeVoidAsync("setTinyMCEContent", post.Content);
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi xử lý tệp: " + ex.Message;
        }
        finally
        {
            isUploadingFile = false;
            isParsingWord = false;
            StateHasChanged();
        }
    }

    private string GetYouTubeEmbed(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        var videoId = "";
        if (url.Contains("v=")) videoId = url.Split("v=")[1].Split("&")[0];
        else if (url.Contains("youtu.be/")) videoId = url.Split("youtu.be/")[1].Split("?")[0];

        if (string.IsNullOrEmpty(videoId)) return $"<p>Link video: {url}</p>";

        return $@"<div class='ratio ratio-16x9'><iframe src='https://www.youtube.com/embed/{videoId}' title='YouTube video' allowfullscreen></iframe></div>";
    }

    private async Task HandleSave()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            // Lấy nội dung mới nhất từ Editor
            if (isEditorInitialized)
            {
                post.Content = await JS.InvokeAsync<string>("getTinyMCEContent", "tiny-editor");
            }

            // Validate dữ liệu
            if (string.IsNullOrWhiteSpace(post.Title)) { errorMessage = "Vui lòng nhập tiêu đề!"; isSubmitting = false; return; }
            if (post.CategoryId == 0) { errorMessage = "Vui lòng chọn chuyên mục!"; isSubmitting = false; return; }

            // Xử lý Video tự động nếu Content trống
            if ((post.SourceType == "Video" || post.SourceType == "Propaganda") && !string.IsNullOrEmpty(post.OriginalUrl))
            {
                if (string.IsNullOrWhiteSpace(post.Content) || post.Content == "<p>&nbsp;</p>")
                {
                    post.Content = GetYouTubeEmbed(post.OriginalUrl);
                }
            }

            bool success = (id > 0) ? await PostService.UpdateAsync(id, post) : await PostService.CreateAsync(post);

            if (success) Nav.NavigateTo("/admin/posts");
            else errorMessage = "Không thể lưu bài viết. Vui lòng kiểm tra lại thông tin.";
        }
        catch (Exception ex) { errorMessage = "Lỗi hệ thống: " + ex.Message; }
        finally { isSubmitting = false; }
    }

    public void Dispose() => JS.InvokeVoidAsync("tinymce.execCommand", "mceRemoveEditor", false, "tiny-editor");
}