﻿
@page "/admin/categories"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject CategoryService categoryService
@inject PhotoUploadService PhotoUploadService
@inject IJSRuntime JS
@inject HttpClient Http
<PageTitle>Quản lý Chuyên mục - Admin</PageTitle>

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-danger rounded-3 p-2 me-3 shadow-sm">
            <i class="bi bi-folder2-open text-white fs-4"></i>
        </div>
        <h2 class="fw-bold m-0" style="color: #1e293b;">QUẢN LÝ CHUYÊN MỤC</h2>
    </div>

    <div class="row">
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow-sm sticky-top" style="top: 20px; z-index: 100;">
                <div class="card-header fw-bold d-flex align-items-center">
                    <i class="bi bi-plus-circle me-2"></i>
                    @(isEditing ? "CẬP NHẬT CHUYÊN MỤC" : "THIẾT LẬP CHUYÊN MỤC MỚI")
                </div>
                <div class="card-body p-4">
                    <EditForm Model="currentCategory" OnValidSubmit="SaveCategory">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tên chuyên mục</label>
                            <InputText @bind-Value="currentCategory.CategoryName" class="form-control" placeholder="Tin tức, Sự kiện..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Chuyên mục cấp cha</label>
                            <select class="form-select" @bind="currentCategory.ParentId">
                                <option value="">-- Cấp cao nhất (Gốc) --</option>
                                @if (categories != null)
                                {
                                    @foreach (var cat in categories.Where(c => c.ParentId == null && c.CategoryId != currentCategory.CategoryId))
                                    {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Đường dẫn thân thiện (Slug)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-link-45deg"></i></span>
                                <InputText @bind-Value="currentCategory.Slug" class="form-control border-start-0 ps-0" placeholder="slug-bai-viet" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Hình ảnh đại diện</label>
                            <InputFile OnChange="HandleFileSelected" class="form-control mb-2" accept="image/*" />
                            
                            @if (!string.IsNullOrEmpty(currentCategory.ImageUrl))
                            {
                                <div class="position-relative d-inline-block">
                                    <img src="@currentCategory.ImageUrl" class="rounded-3 shadow-sm border" style="width: 100%; max-height: 160px; object-fit: cover;" />
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="cursor:pointer" @onclick="() => currentCategory.ImageUrl = null">
                                        <i class="bi bi-x"></i>
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 d-md-flex">
                            <button type="submit" class="btn btn-danger flex-grow-1 fw-bold py-2 shadow-sm" disabled="@isUploading">
                                <i class="bi bi-save me-1"></i> LƯU DỮ LIỆU
                            </button>
                            @if (isEditing)
                            {
                                <button type="button" class="btn btn-light border flex-grow-1 fw-bold py-2" @onclick="ResetForm">
                                    HỦY
                                </button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="card shadow-sm overflow-hidden">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Hình ảnh</th>
                                    <th>Cấu trúc chuyên mục</th>
                                    <th>Slug</th>
                                    <th class="text-end pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (categories != null)
                                {
                                    @foreach (var parent in categories.Where(c => c.ParentId == null))
                                    {
                                        <tr class="parent-row">
                                            <td class="ps-4">
                                                <img src="@(string.IsNullOrEmpty(parent.ImageUrl) ? "Images/Logo_hoc_vien_ANND.png" : parent.ImageUrl)"
                                                     class="category-img" style="width: 60px; height: 40px;" />
                                            </td>
                                            <td>
                                                <div class="fw-bold text-navy">@parent.CategoryName</div>
                                                <span class="badge bg-danger-soft text-danger small" style="font-size: 0.65rem; background: #fee2e2;">ROOT</span>
                                            </td>
                                            <td><code class="text-muted small">/@parent.Slug</code></td>
                                            <td class="text-end pe-4">
                                                <button class="btn-action" @onclick="() => EditCategory(parent)" title="Sửa"><i class="bi bi-pencil-fill text-primary"></i></button>
                                                <button class="btn-action ms-1" @onclick="() => DeleteCategory(parent.CategoryId)" title="Xóa"><i class="bi bi-trash3-fill text-danger"></i></button>
                                            </td>
                                        </tr>

                                        @foreach (var child in categories.Where(c => c.ParentId == parent.CategoryId))
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <img src="@(string.IsNullOrEmpty(child.ImageUrl) ? "Images/Logo_hoc_vien_ANND.png" : child.ImageUrl)"
                                                         class="category-img ms-4" style="width: 45px; height: 32px;" />
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center ms-4">
                                                        <span class="child-indicator">└─</span>
                                                        <span class="text-secondary fw-medium">@child.CategoryName</span>
                                                    </div>
                                                </td>
                                                <td class="ps-5"><code class="text-muted small">/@child.Slug</code></td>
                                                <td class="text-end pe-4">
                                                    <button class="btn-action" @onclick="() => EditCategory(child)"><i class="bi bi-pencil text-primary"></i></button>
                                                    <button class="btn-action ms-1" @onclick="() => DeleteCategory(child.CategoryId)"><i class="bi bi-x-circle text-danger"></i></button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
/* Tông màu chủ đạo */
:root {
    --primary-navy: #1a237e;
    --accent-red: #d32f2f;
    --glass-bg: rgba(255, 255, 255, 0.95);
    --border-color: #edf2f7;
}

/* Card & Container */
.card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04) !important;
}

.card-header {
    background: #1e293b !important; /* Màu xanh đen hiện đại */
    color: white !important;
    border-radius: 16px 16px 0 0 !important;
    padding: 1.2rem;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
}

/* Table Design */
.table thead th {
    background: #f8fafc;
    border-bottom: 2px solid var(--border-color);
    color: #64748b;
    font-size: 0.75rem;
    text-transform: uppercase;
    padding: 1rem;
}

.table tbody tr {
    transition: all 0.2s ease;
}

.table tbody tr:hover {
    background-color: #f1f5f9 !important;
    transform: scale(1.005);
}

/* Phân cấp Cha - Con */
.parent-row {
    border-left: 4px solid var(--accent-red);
}

.child-indicator {
    color: #cbd5e1;
    font-size: 1.2rem;
    margin-right: 8px;
    font-family: serif;
}

/* Form Styling */
.form-label {
    font-size: 0.85rem;
    color: #475569;
    margin-bottom: 0.5rem;
}

.form-control, .form-select {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
}

.form-control:focus {
    border-color: var(--accent-red);
    box-shadow: 0 0 0 3px rgba(211, 47, 47, 0.1);
}

/* Image styling */
.category-img {
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    background: #f1f5f9;
}

/* Buttons */
.btn-action {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.2s;
    background: white;
    border: 1px solid #e2e8f0;
}

.btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}
</style>
@code {
    private List<CategoryDto>? categories;
    private CategoryDto currentCategory = new CategoryDto();
    private bool isEditing = false;
    private bool isUploading = false;
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await categoryService.GetAllAsync();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        isUploading = true;
        StateHasChanged();

        var uploadedUrl = await PhotoUploadService.UploadPhotoAsync(selectedFile);

        if (!string.IsNullOrEmpty(uploadedUrl))
        {
            currentCategory.ImageUrl = uploadedUrl;
        }

        isUploading = false;
        StateHasChanged();
    }

    private async Task SaveCategory()
    {
        if (isEditing)
        {
            await categoryService.UpdateAsync(currentCategory.CategoryId, currentCategory);
        }
        else
        {
            await categoryService.CreateAsync(currentCategory);
        }

        await LoadCategories();
        ResetForm();
    }

    private void EditCategory(CategoryDto cat)
    {
        isEditing = true;
        currentCategory = new CategoryDto
            {
                CategoryId = cat.CategoryId,
                CategoryName = cat.CategoryName,
                Slug = cat.Slug,
                ParentId = cat.ParentId,
                ImageUrl = cat.ImageUrl
            };
    }

    private async Task DeleteCategory(int id)
    {
        // Hiện thông báo cảnh báo cực gắt
        bool confirmed = await JS.InvokeAsync<bool>("confirm",
            "CẢNH BÁO ĐỎ: Hành động này sẽ xóa SẠCH SÀNH SANH chuyên mục này, bao gồm toàn bộ CHUYÊN MỤC CON, BÀI VIẾT, BÌNH LUẬN và CÂU HỎI bên trong!\n\nBạn có chắc chắn muốn 'tuyệt diệt' nó không?");

        // Nếu người dùng bấm Cancel -> Dừng lại ngay
        if (!confirmed) return;

        // Nếu bấm OK -> Gửi lệnh tử hình lên API
        var response = await Http.DeleteAsync($"api/Categories/{id}");

        if (response.IsSuccessStatusCode)
        {
            await LoadCategories(); // Tải lại danh sách
            await JS.InvokeVoidAsync("alert", "Đã quét sạch mọi thứ thành công!");
        }
        else
        {
            var errorMessage = await response.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", errorMessage);
        }
    }

    private void ResetForm()
    {
        isEditing = false;
        currentCategory = new CategoryDto();
        selectedFile = null;
    }
}