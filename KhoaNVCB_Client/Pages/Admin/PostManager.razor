@page "/admin/posts"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject PostService PostService
@inject CategoryService CategoryService
@inject ScraperService ScraperService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Quản lý Bài viết - Admin</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="fw-bold m-0 border-start border-danger border-4 ps-2" style="color: #1a237e;">QUẢN LÝ BÀI VIẾT</h2>
        <div class="d-flex gap-2">
            @* Nút tải lại dữ liệu nhanh *@
            <button class="btn btn-outline-primary fw-bold shadow-sm d-inline-flex align-items-center"
                    @onclick="RefreshData" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-1 @(isLoading ? "ani-spin" : "")"
                   style="font-size: 1.1rem; display: inline-block;"></i>
                <span>LÀM MỚI</span>
            </button>
            <a href="/admin/posts/create" class="btn btn-danger fw-bold shadow-sm">
                <i class="oi oi-plus me-1"></i> VIẾT BÀI MỚI
            </a>
        </div>
    </div>

    @* TABS *@
    <ul class="nav nav-tabs mb-4 fw-bold">
        <li class="nav-item">
            <a class="nav-link @(activeTab == "Published" ? "active text-danger" : "text-secondary")"
               @onclick='() => SwitchTab("Published")' style="cursor:pointer">
                BÀI ĐÃ ĐĂNG (@(posts?.Count ?? 0))
            </a>
        </li>
    </ul>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0 table-responsive" style="min-height: 400px;">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase" style="font-size: 0.85rem;">
                    <tr>
                        <th class="ps-3" style="width: 100px;">Ảnh</th>
                        <th>Nội dung bài viết</th>
                        <th>Chuyên mục</th>
                        <th>Ngày tạo</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        @* Giữ nguyên skeleton *@
                    }
                    else
                    {
                        @* Dùng Virtualize thay cho foreach *@
                        <Virtualize Items="posts" Context="post" OverscanCount="5">
                            <tr class="animate-fade-in">
                                <td class="ps-3">
                                    <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/Images/Logo_hoc_vien_ANND.png" : post.ImageUrl)"
                                         class="rounded shadow-sm"
                                         style="width: 70px; height: 45px; object-fit: cover;"
                                         onerror="this.src='/images/no-image-available.png';" />
                                </td>
                                <td>
                                    <div class="fw-bold text-navy text-truncate" style="max-width: 400px;">@post.Title</div>
                                    <div class="small text-muted text-truncate" style="max-width: 400px;">@post.Summary</div>
                                </td>
                                <td><span class="badge bg-gold-soft text-gold">@post.CategoryName</span></td>
                                <td class="small text-muted">@post.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end pe-3">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditPost(post.PostId)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePost(post.PostId, post.Title)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </Virtualize>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Làm rõ khung ảnh */
    .ps-3 img {
        background-color: #f0f0f0;
        display: block;
        min-width: 70px;
        min-height: 45px;
    }

    /* Định dạng lại nhóm nút thao tác */
    .btn-group .btn {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 35px;
        height: 35px;
        border: 1px solid #dee2e6 !important; /* Ép viền hiện lên */
        margin-left: 5px;
    }

    /* Hiệu ứng khi hover vào hàng */
    tr:hover {
        background-color: rgba(26, 35, 126, 0.05) !important;
    }

    /* Nếu dùng Open Iconic, đảm bảo font-family đúng */
    .oi {
        font-family: 'Icons'; /* Tên font tùy thuộc thư viện bạn dùng */
        font-style: normal;
    }
    /* Tổng thể container */
    .container {
        max-width: 1200px;
        animation: fadeIn 0.5s ease-in-out;
    }

    /* Màu sắc tùy chỉnh */
    :root {
        --navy-blue: #1a237e;
        --gold-bg: #fff9c4;
        --gold-text: #fbc02d;
        --transition-speed: 0.3s;
    }

    /* Hiệu ứng chuyển động cho hàng trong bảng */
    .animate-fade-in {
        animation: slideUp 0.4s ease forwards;
    }

    @@eyframes slideUp {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* Làm đẹp Table */
    .table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #edf2f7;
    }

        .table thead th {
            font-weight: 700;
            color: #4a5568;
            letter-spacing: 0.05em;
            padding: 1rem 0.75rem;
        }

    .table tbody tr {
        transition: all var(--transition-speed);
        border-bottom: 1px solid #f1f1f1;
    }

        .table tbody tr:hover {
            background-color: #fcfcfd !important;
            transform: scale(1.002);
            box-shadow: inset 4px 0 0 var(--navy-blue);
        }

    /* Badge chuyên mục */
    .bg-gold-soft {
        background-color: var(--gold-bg);
        color: #856404;
        padding: 0.5em 0.8em;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.75rem;
    }

    /* Tabs hiện đại */
    .nav-tabs {
        border-bottom: 2px solid #edf2f7;
    }

        .nav-tabs .nav-link {
            border: none;
            padding: 1rem 1.5rem;
            position: relative;
            transition: color 0.3s ease;
        }

            .nav-tabs .nav-link.active {
                background: transparent;
                border: none;
                color: var(--navy-blue) !important;
            }

                .nav-tabs .nav-link.active::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 100%;
                    height: 3px;
                    background: #dc3545; /* Màu đỏ như border-danger của bạn */
                    border-radius: 3px 3px 0 0;
                }

    /* Nút bấm (Buttons) */
    .btn-white {
        background: #fff;
        transition: all 0.2s;
    }

        .btn-white:hover {
            background: #f8f9fa;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

    .btn-group .btn {
        padding: 0.4rem 0.7rem;
        margin: 0 2px;
    }

    /* Ảnh xem trước */
    img.rounded {
        border: 2px solid #fff;
        transition: transform 0.3s ease;
    }

    tr:hover img.rounded {
        transform: scale(1.1);
    }

    /* Icon xoay khi loading */
    .ani-spin {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    /* Custom Scrollbar cho table responsive */
    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }

    .table-responsive::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }
</style>


@code {
    private string activeTab = "Published";
    private List<PostListItemDto> posts = new(); // Khởi tạo list rỗng để tránh null check liên tục
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Gọi dữ liệu ngay tại đây
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Gọi hàm mới siêu nhẹ
            var allPosts = await PostService.GetAdminPostsAsync();

            if (allPosts != null)
            {
                posts = allPosts
                    .Where(p => p.Status == activeTab)
                    .OrderByDescending(p => p.CreatedDate)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.log", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // TỐI ƯU 3: Sử dụng phương thức không đồng bộ thực sự cho Tab
    private async Task SwitchTab(string tabName)
    {
        if (activeTab == tabName) return;
        activeTab = tabName;
        posts.Clear(); // Xóa list cũ để hiện skeleton ngay
        await LoadData();
    }
    private async Task RefreshData() => await LoadData();

    

    private void EditPost(int id) => Nav.NavigateTo($"/admin/posts/edit/{id}");

    private async Task DeletePost(int id, string title)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Xóa bài viết: {title}?");
        if (confirm)
        {
            var success = await PostService.DeleteAsync(id);
            if (success) await LoadData();
        }
    }
}