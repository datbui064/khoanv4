@page "/admin/posts"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject PostService PostService
@inject CategoryService CategoryService
@inject ScraperService ScraperService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Quản lý Bài viết - Admin</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="fw-bold m-0 border-start border-danger border-4 ps-2" style="color: #1a237e;">QUẢN LÝ BÀI VIẾT</h2>
        <div class="d-flex gap-2">
            @* Nút tải lại dữ liệu nhanh *@
            <button class="btn btn-outline-primary fw-bold" @onclick="RefreshData" disabled="@isLoading">
                <i class="oi oi-reload @(isLoading ? "ani-spin" : "")"></i>
            </button>
            <a href="/admin/posts/create" class="btn btn-danger fw-bold shadow-sm">
                <i class="oi oi-plus me-1"></i> VIẾT BÀI MỚI
            </a>
        </div>
    </div>

    @* TABS *@
    <ul class="nav nav-tabs mb-4 fw-bold">
        <li class="nav-item">
            <a class="nav-link @(activeTab == "Published" ? "active text-danger" : "text-secondary")"
               @onclick='() => SwitchTab("Published")' style="cursor:pointer">
                BÀI ĐÃ ĐĂNG (@(posts?.Count ?? 0))
            </a>
        </li>
    </ul>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0 table-responsive" style="min-height: 400px;">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase" style="font-size: 0.85rem;">
                    <tr>
                        <th class="ps-3" style="width: 100px;">Ảnh</th>
                        <th>Nội dung bài viết</th>
                        <th>Chuyên mục</th>
                        <th>Ngày tạo</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        @* Giữ nguyên skeleton *@
                    }
                    else
                    {
                        @* Dùng Virtualize thay cho foreach *@
                        <Virtualize Items="posts" Context="post" OverscanCount="5">
                            <tr class="animate-fade-in">
                                <td class="ps-3">
                                    <img src="@post.ImageUrl" class="rounded shadow-sm"
                                         style="width: 70px; height: 45px; object-fit: cover;" />
                                </td>
                                <td>
                                    <div class="fw-bold text-navy text-truncate" style="max-width: 400px;">@post.Title</div>
                                    <div class="small text-muted text-truncate" style="max-width: 400px;">@post.Summary</div>
                                </td>
                                <td><span class="badge bg-gold-soft text-gold">@post.CategoryName</span></td>
                                <td class="small text-muted">@post.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end pe-3">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-white border" @onclick="() => EditPost(post.PostId)">
                                            <i class="oi oi-pencil text-primary"></i>
                                        </button>
                                        <button class="btn btn-sm btn-white border" @onclick="() => DeletePost(post.PostId, post.Title)">
                                            <i class="oi oi-trash text-danger"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </Virtualize>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-navy {
        color: #1a237e;
    }

    .bg-gold-soft {
        background-color: rgba(197, 160, 89, 0.1);
        color: #b08d4a;
        border: 1px solid rgba(197, 160, 89, 0.2);
    }

    .btn-white {
        background: #fff;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    /* Hiệu ứng xoay khi loading */
    .ani-spin {
        animation: spin 1s linear infinite;
    }
    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    /* Skeleton Loading Table */
    .skeleton-row {
        height: 70px;
    }

    .skeleton-line {
        height: 20px;
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: loading-shimmer 1.5s infinite;
        border-radius: 4px;
        margin: 10px;
    }
    @@keyframes loading-shimmer {
        to

    {
        background-position: -200% 0;
    }

    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-in;
    }
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }</style>

@code {
    private string activeTab = "Published";
    private List<PostListItemDto> posts = new(); // Khởi tạo list rỗng để tránh null check liên tục
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Gọi dữ liệu ngay tại đây
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Gọi hàm mới siêu nhẹ
            var allPosts = await PostService.GetAdminPostsAsync();

            if (allPosts != null)
            {
                posts = allPosts
                    .Where(p => p.Status == activeTab)
                    .OrderByDescending(p => p.CreatedDate)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.log", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // TỐI ƯU 3: Sử dụng phương thức không đồng bộ thực sự cho Tab
    private async Task SwitchTab(string tabName)
    {
        if (activeTab == tabName) return;
        activeTab = tabName;
        posts.Clear(); // Xóa list cũ để hiện skeleton ngay
        await LoadData();
    }
    private async Task RefreshData() => await LoadData();

    

    private void EditPost(int id) => Nav.NavigateTo($"/admin/posts/edit/{id}");

    private async Task DeletePost(int id, string title)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Xóa bài viết: {title}?");
        if (confirm)
        {
            var success = await PostService.DeleteAsync(id);
            if (success) await LoadData();
        }
    }
}