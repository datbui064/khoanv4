@page "/category/{id:int}"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization

@inject CategoryService CategoryService

<PageTitle>@(category?.CategoryName ?? "Chuyên mục") - Khoa NV4</PageTitle>

<div class="container py-5">
    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-danger" role="status"></div></div>
    }
    else if (category == null)
    {
        <div class="alert alert-warning text-center shadow-sm">Không tìm thấy chuyên mục này.</div>
    }
    else
    {
        <div class="text-center mb-5 mx-auto" style="max-width: 800px;">
            <h2 class="fw-bold text-uppercase mb-3" style="color: #1a237e;">@category.CategoryName</h2>
            <div class="divider mx-auto mb-3" style="width: 50px; height: 3px; background-color: #d32f2f;"></div>
            <p class="text-muted">Vui lòng chọn loại nội dung bạn muốn truy cập trong lĩnh vực này.</p>
        </div>

        <div class="row g-4 justify-content-center">
            @* 1. Tin Tức *@
            <div class="col-md-6 col-lg-3">
                <a href="/category/@id/articles" class="text-decoration-none">
                    <div class="nav-card h-100 shadow-sm border-0 rounded-4 p-4 text-center">
                        <div class="icon-circle bg-primary-light mb-3">
                            <i class="oi oi-document text-primary"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Tin Tức</h5>
                        <p class="small text-muted mb-0">Hoạt động, tin tức sự kiện mới nhất.</p>
                    </div>
                </a>
            </div>

            @* 2. Video *@
            <div class="col-md-6 col-lg-3">
                <a href="/category/@id/videos" class="text-decoration-none">
                    <div class="nav-card h-100 shadow-sm border-0 rounded-4 p-4 text-center">
                        <div class="icon-circle bg-danger-light mb-3">
                            <i class="oi oi-video text-danger"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Video</h5>
                        <p class="small text-muted mb-0">Phóng sự và tư liệu ghi hình.</p>
                    </div>
                </a>
            </div>

            @* 3. Quy định pháp luật *@
            <div class="col-md-6 col-lg-3">
                <a href="/category/@id/laws" class="text-decoration-none">
                    <div class="nav-card h-100 shadow-sm border-0 rounded-4 p-4 text-center">
                        <div class="icon-circle bg-warning-light mb-3">
                            <i class="oi oi-shield text-warning"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Quy định pháp luật</h5>
                        <p class="small text-muted mb-0">Hành lang pháp lý và quy tắc.</p>
                    </div>
                </a>
            </div>

            @* 4. Văn bản liên quan *@
            <div class="col-md-6 col-lg-3">
                <a href="/category/@id/documents" class="text-decoration-none">
                    <div class="nav-card h-100 shadow-sm border-0 rounded-4 p-4 text-center">
                        <div class="icon-circle bg-info-light mb-3">
                            <i class="oi oi-folder text-info"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Văn bản liên quan</h5>
                        <p class="small text-muted mb-0">Công văn, chỉ thị và tài liệu hướng dẫn.</p>
                    </div>
                </a>
            </div>
        </div>
    }
</div>

<style>
    .nav-card {
        background: #ffffff;
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-bottom: 4px solid transparent !important;
    }

        .nav-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            background-color: #fcfcfc;
        }

    /* Đổi màu viền khi hover tùy từng card */
    .col-md-6:nth-child(1) .nav-card:hover {
        border-bottom-color: #0d6efd !important;
    }

    .col-md-6:nth-child(2) .nav-card:hover {
        border-bottom-color: #dc3545 !important;
    }

    .col-md-6:nth-child(3) .nav-card:hover {
        border-bottom-color: #ffc107 !important;
    }

    .col-md-6:nth-child(4) .nav-card:hover {
        border-bottom-color: #0dcaf0 !important;
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        line-height: 70px;
        border-radius: 50%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    /* Màu nền nhẹ cho icon */
    .bg-primary-light {
        background: #e7f1ff;
    }

    .bg-danger-light {
        background: #ffeef0;
    }

    .bg-warning-light {
        background: #fff9e6;
    }

    .bg-info-light {
        background: #e1faff;
    }
</style>

@code {
    [Parameter] public int id { get; set; }
    private CategoryDto? category;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() => await LoadCategory();
    protected override async Task OnParametersSetAsync() => await LoadCategory();

    private async Task LoadCategory()
    {
        isLoading = true;
        var allCats = await CategoryService.GetAllAsync();
        category = allCats.FirstOrDefault(c => c.CategoryId == id);
        isLoading = false;
    }
}