@page "/category/{id:int}/{type}"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization

@inject PostService PostService
@inject CategoryService CategoryService

<PageTitle>@GetTypeName(type) - @currentCategory?.CategoryName</PageTitle>

<div class="container py-5">
    <div class="row g-5">
        @* CỘT TRÁI: DANH SÁCH BÀI VIẾT *@
        <div class="col-lg-8">
            <div class="category-header mb-4">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="/category/@id" class="text-decoration-none text-muted">@currentCategory?.CategoryName</a></li>
                        <li class="breadcrumb-item active text-danger">@GetTypeName(type)</li>
                    </ol>
                </nav>
                <h2 class="fw-bold text-uppercase ps-3 border-start border-4 border-danger">
                    @GetTypeName(type)
                </h2>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5"><div class="spinner-grow text-danger"></div></div>
            }
            else if (filteredPosts == null || !filteredPosts.Any())
            {
                <div class="text-center py-5 bg-white shadow-sm rounded-4 border">
                    <i class="oi oi-document fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Hiện chưa có nội dung nào trong mục này.</p>
                </div>
            }
            else
            {
                <div class="list-container">
                    @foreach (var post in filteredPosts)
                    {
                        <div class="card mb-3 border-0 shadow-sm post-list-card overflow-hidden">
                            <div class="row g-0 align-items-center">
                                <div class="col-3 col-md-2 p-2">
                                    <div class="ratio ratio-1x1 overflow-hidden rounded-3 border">
                                        <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : post.ImageUrl)" class="object-fit-cover" alt="@post.Title" />
                                    </div>
                                </div>
                                <div class="col-9 col-md-10">
                                    <div class="card-body py-2 px-3">
                                        <a href="/post/@post.PostId" class="text-decoration-none stretched-link">
                                            <h5 class="card-title fw-bold text-dark mb-1 fs-6 line-clamp-2">@post.Title</h5>
                                        </a>
                                        <p class="card-text text-muted small mb-2 d-none d-md-block line-clamp-1">@post.Summary</p>
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="text-muted small"><i class="oi oi-calendar me-1"></i> @post.CreatedDate?.ToString("dd/MM/yyyy")</span>
                                            @if (type == "documents")
                                            {
                                                <span class="badge bg-info text-white">Văn bản</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* CỘT PHẢI: SIDEBAR CHUYÊN MỤC *@
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 2rem;">
                <div class="modern-sidebar p-4 bg-white shadow-sm rounded-4">
                    <h6 class="fw-bold mb-3 text-uppercase border-bottom pb-2">Chuyên mục khác</h6>
                    <div class="category-stack d-flex flex-column gap-2">
                        @if (categories != null)
                        {
                            @foreach (var cat in categories.Where(c => c.ParentId == null))
                            {
                                <a href="/category/@cat.CategoryId/@type" class="category-link @(cat.CategoryId == id ? "active" : "")">
                                    <span class="small fw-bold">@cat.CategoryName</span>
                                    <i class="oi oi-chevron-right small"></i>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .post-list-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }

        .post-list-card:hover .card-title {
            color: #dc3545 !important;
        }

    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .category-link {
        display: flex;
        justify-content: space-between;
        padding: 12px;
        border-radius: 8px;
        text-decoration: none;
        color: #444;
        background: #f8f9fa;
        transition: 0.3s;
    }

        .category-link:hover {
            background: #fff;
            color: #dc3545;
            padding-left: 18px;
        }

        .category-link.active {
            background: #dc3545;
            color: #fff !important;
        }
</style>

@code {
    [Parameter] public int id { get; set; }
    [Parameter] public string type { get; set; } = "articles";

    private bool isLoading = true;
    private CategoryDto? currentCategory;
    private List<CategoryDto>? categories;
    private List<PostDto>? filteredPosts;

    private string GetTypeName(string t) => t.ToLower() switch
    {
        "articles" => "Tin tức",
        "videos" => "Video",
        "laws" => "Quy định pháp luật",
        "documents" => "Văn bản liên quan",
        _ => "Nội dung"
    };

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        if (categories == null) categories = await CategoryService.GetAllAsync();
        currentCategory = categories?.FirstOrDefault(c => c.CategoryId == id);

        var result = await PostService.GetPagedPostsAsync(page: 1, pageSize: 20, categoryId: id, sourceType: type);
        filteredPosts = result.Posts;
        isLoading = false;
    }
}