@page "/"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject PostService PostService
@inject CategoryService CategoryService

<PageTitle>Trang chủ - Khoa An ninh Nội bộ</PageTitle>

@* --- HERO SECTION HIỆN ĐẠI --- *@
<div class="hero-wrapper">
    <video autoplay loop muted playsinline class="hero-video" poster="/Images/Logo_hoc_vien_ANND.png">
        <source src="/Images/video-nen-2.mp4" type="video/mp4">
    </video>
    <div class="hero-glass-overlay">
        <div class="container text-center text-white">
            <span class="badge rounded-pill bg-gold mb-3 px-3 py-2 text-uppercase fw-bold animate-fade-in">Học viện An ninh Nhân dân</span>
            <h1 class="hero-main-title">KHOA AN NINH CHÍNH TRỊ NỘI BỘ</h1>
            <div class="hero-divider"></div>
            <p class="hero-description">
                Nền tảng tri thức số chuyên biệt về nghiệp vụ bảo vệ chính trị nội bộ.
                Kết nối lý luận khoa học và thực tiễn chiến đấu.
            </p>
            <div class="mt-4 d-flex justify-content-center gap-3">
                <a href="/categories" class="btn btn-gold btn-lg px-4 fw-bold">Khám phá tài liệu</a>
                <a href="#featured-posts" class="btn btn-outline-light btn-lg px-4">Tin tức mới nhất</a>
            </div>
        </div>
    </div>
</div>

<div class="container mt-n5 position-relative z-index-3">
    @* --- STATS BAR (Điểm nhấn hiện đại) --- *@
    <div class="row g-0 shadow-lg rounded-4 overflow-hidden bg-white text-center mb-5 border">
        <div class="col-md-4 p-4 border-end">
            <h3 class="fw-bold text-navy mb-0">1,200+</h3>
            <small class="text-muted text-uppercase fw-semibold">Tài liệu nghiệp vụ</small>
        </div>
        <div class="col-md-4 p-4 border-end">
            <h3 class="fw-bold text-navy mb-0">50+</h3>
            <small class="text-muted text-uppercase fw-semibold">Giảng viên chuyên gia</small>
        </div>
        <div class="col-md-4 p-4">
            <h3 class="fw-bold text-navy mb-0">24/7</h3>
            <small class="text-muted text-uppercase fw-semibold">Truy cập trực tuyến</small>
        </div>
    </div>

    @* --- BÀI VIẾT NỔI BẬT --- *@
    <section id="featured-posts" class="mb-5">
        <div class="section-header d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="section-title">Tin tức nổi bật</h2>
                <div class="section-underline"></div>
            </div>
            <a href="/posts" class="text-navy fw-bold text-decoration-none">Xem tất cả <i class="oi oi-arrow-right"></i></a>
        </div>

        @if (recentPosts == null)
        {
            <div class="text-center py-5"><div class="spinner-grow text-navy" role="status"></div></div>
        }
        else
        {
            <div class="post-list-container">
                @foreach (var post in recentPosts)
                {
                    <div class="modern-post-list-item">
                        <div class="post-list-thumb">
                            <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : post.ImageUrl)" alt="@post.Title" />
                            <span class="post-category-tag">@(post.CategoryName ?? "Mới")</span>
                        </div>
                        <div class="post-list-body">
                            <div class="post-list-meta">
                                <span class="meta-item"><i class="oi oi-calendar"></i> @post.CreatedDate?.ToString("dd/MM/yyyy")</span>
                                <span class="meta-item"><i class="oi oi-person"></i> Ban Biên Tập</span>
                            </div>
                            <h4 class="post-list-title">
                                <a href="/post/@post.PostId">@post.Title</a>
                            </h4>
                            <p class="post-list-excerpt">
                                @(post.Summary ?? "Bản tin cập nhật những kiến thức mới nhất về công tác an ninh chính trị nội bộ và thực tiễn chiến đấu...")
                            </p>
                            <div class="post-list-footer">
                                <a href="/post/@post.PostId" class="read-more-link">
                                    Đọc chi tiết <i class="oi oi-chevron-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* --- CHUYÊN MỤC TÀI LIỆU (GRID LAYOUT MỚI) --- *@
    <section class="mb-5 py-4">
        <div class="text-center mb-5">
            <h2 class="section-title mx-auto">Chuyên mục tài liệu</h2>
            <p class="text-muted">Hệ thống hóa tri thức theo từng mảng nghiệp vụ chuyên sâu</p>
        </div>

        @if (categories != null)
        {
            <div class="row g-4">
                @foreach (var cat in categories.Where(c => c.ParentId == null))
                {
                    <div class="col-lg-4 col-md-6">
                        <a href="/category/@cat.CategoryId" class="category-luxury-card">
                            <div class="category-image">
                                <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : cat.ImageUrl)" alt="@cat.CategoryName" />
                            </div>
                            <div class="category-overlay"></div>
                            <div class="category-content">
                                
                                @* ----------------------------- *@

                                <h4 class="category-name">@cat.CategoryName</h4>
                                <div class="category-details">
                                    <p>Khám phá kho tài liệu nghiệp vụ chuyên sâu về @(cat.CategoryName?.ToLower() ?? "chuyên mục này").</p>
                                    <span class="category-link">Truy cập ngay <i class="oi oi-arrow-right ms-2"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </section>
</div>
@* --- SECTION: ĐỘI NGŨ GIẢNG VIÊN & CHUYÊN GIA --- *@
<section class="faculty-section py-5 px-3">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge rounded-pill bg-gold-light text-gold px-3 py-2 mb-2 fw-bold">NHÂN SỰ NÒNG CỐT</span>
            <h2 class="section-title mx-auto">Đội ngũ Giảng viên & Chuyên gia</h2>
            <div class="section-underline mx-auto"></div>
            <p class="text-muted mt-3">Hội tụ những nhà khoa học tâm huyết, kinh nghiệm thực tiễn và tư duy nghiệp vụ sắc bén</p>
        </div>

        <div class="row g-4">
            @* Giảng viên 1 *@
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card">
                    <div class="faculty-image">
                        <img src="/Images/Logo_hoc_vien_ANND.png" alt="Giảng viên" />
                        <div class="faculty-socials">
                            <a href="#"><i class="fa-solid fa-envelope"></i></a>
                            <a href="#"><i class="fa-solid fa-graduation-cap"></i></a>
                        </div>
                    </div>
                    <div class="faculty-info text-center p-4">
                        <h5 class="faculty-name">PGS, TS. NGUYỄN VĂN A</h5>
                        <p class="faculty-rank">Giảng viên Cao cấp - Trưởng Khoa</p>
                        <hr class="short-hr mx-auto">
                        <p class="faculty-bio">Chuyên gia đầu ngành với hơn 25 năm kinh nghiệm nghiên cứu lý luận bảo vệ chính trị nội bộ.</p>
                        <div class="faculty-tags">
                            <span class="badge bg-light text-navy border">Lý luận</span>
                            <span class="badge bg-light text-navy border">Nghiệp vụ</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Giảng viên 2 *@
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card">
                    <div class="faculty-image">
                        <img src="/Images/Logo_hoc_vien_ANND.png" alt="Giảng viên" />
                        <div class="faculty-socials">
                            <a href="#"><i class="fa-solid fa-envelope"></i></a>
                            <a href="#"><i class="fa-solid fa-graduation-cap"></i></a>
                        </div>
                    </div>
                    <div class="faculty-info text-center p-4">
                        <h5 class="faculty-name">TS. TRẦN THỊ B</h5>
                        <p class="faculty-rank">Giảng viên Chính - Phó Trưởng Khoa</p>
                        <hr class="short-hr mx-auto">
                        <p class="faculty-bio">Nghiên cứu chuyên sâu về các phương thức thủ đoạn mới của các thế lực thù địch hiện nay.</p>
                        <div class="faculty-tags">
                            <span class="badge bg-light text-navy border">Thực tiễn</span>
                            <span class="badge bg-light text-navy border">Đối ngoại</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Bạn có thể copy thêm các khối tương tự cho Giảng viên 3, 4... *@
            @* Giảng viên 3 *@
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card">
                    <div class="faculty-image">
                        <img src="/Images/Logo_hoc_vien_ANND.png" alt="Giảng viên" />
                        <div class="faculty-socials">
                            <a href="#"><i class="fa-solid fa-envelope"></i></a>
                            <a href="#"><i class="fa-solid fa-graduation-cap"></i></a>
                        </div>
                    </div>
                    <div class="faculty-info text-center p-4">
                        <h5 class="faculty-name">THS. LÊ VĂN C</h5>
                        <p class="faculty-rank">Giảng viên nghiệp vụ</p>
                        <hr class="short-hr mx-auto">
                        <p class="faculty-bio">Dày dạn kinh nghiệm thực tế chiến đấu tại các địa bàn trọng điểm về an ninh nội bộ.</p>
                        <div class="faculty-tags">
                            <span class="badge bg-light text-navy border">Kỹ năng</span>
                            <span class="badge bg-light text-navy border">Địa bàn</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Giảng viên 4 *@
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card h-100 d-flex flex-column justify-content-center align-items-center border-dashed p-4">
                    <div class="add-expert-circle mb-3">
                        <i class="fa-solid fa-users-viewfinder"></i>
                    </div>
                    <h6 class="text-muted fw-bold">Và hơn 20 giảng viên</h6>
                    <p class="small text-center text-muted">Đang trực tiếp giảng dạy tại Khoa</p>
                    <a href="#" class="btn btn-sm btn-outline-gold mt-2">Xem danh sách đầy đủ</a>
                </div>
            </div>
        </div>
    </div>
</section>


<style>
    /* FACULTY SECTION STYLES */
    .faculty-section {
        background-color: #fcfdfe;
    }

    .bg-gold-light {
        background-color: rgba(197, 160, 89, 0.15);
    }

    .text-gold {
        color: #c5a059 !important;
    }

    .faculty-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(10, 25, 47, 0.05);
        transition: all 0.4s ease;
        height: 100%;
        border: 1px solid rgba(0,0,0,0.03);
    }

        .faculty-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(10, 25, 47, 0.12);
        }

    .faculty-image {
        position: relative;
        height: 250px;
        overflow: hidden;
        background-color: #f8f9fa;
    }

        .faculty-image img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* Phù hợp với ảnh logo Học viện ANND của bạn */
            padding: 30px;
            transition: transform 0.5s ease;
        }

    .faculty-card:hover .faculty-image img {
        transform: scale(1.1);
    }

    /* Hiệu ứng trượt mạng xã hội khi hover */
    .faculty-socials {
        position: absolute;
        bottom: -50px;
        left: 0;
        width: 100%;
        height: 50px;
        background: rgba(10, 25, 47, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        transition: bottom 0.3s ease;
    }

    .faculty-card:hover .faculty-socials {
        bottom: 0;
    }

    .faculty-socials a {
        color: #c5a059;
        font-size: 1.1rem;
        transition: color 0.2s;
    }

        .faculty-socials a:hover {
            color: #fff;
        }

    .faculty-info {
        background: white;
    }

    .faculty-name {
        color: #0a192f;
        font-weight: 800;
        font-size: 1rem;
        margin-bottom: 5px;
    }

    .faculty-rank {
        color: #c5a059;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .short-hr {
        width: 30px;
        height: 2px;
        background-color: #eee;
        border: 0;
        margin: 15px 0;
    }

    .faculty-bio {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.5;
        height: 60px; /* Giữ các card đều nhau */
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }

    .faculty-tags {
        display: flex;
        justify-content: center;
        gap: 5px;
        margin-top: 15px;
    }

    /* Dành cho card "Xem thêm" */
    .border-dashed {
        border: 2px dashed #ddd !important;
        border-radius: 20px;
        background: transparent !important;
    }

    .add-expert-circle {
        width: 60px;
        height: 60px;
        background: #f0f2f5;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #ccc;
    }

    .btn-outline-gold {
        border-color: #c5a059;
        color: #c5a059;
        border-radius: 20px;
        font-weight: 600;
    }

        .btn-outline-gold:hover {
            background-color: #c5a059;
            color: white;
        }
    /* CATEGORY LUXURY CARD */
    .category-luxury-card {
        position: relative;
        display: block;
        height: 320px;
        border-radius: 20px;
        overflow: hidden;
        text-decoration: none !important;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .category-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

        .category-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

    /* Lớp phủ Gradient đa tầng */
    .category-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(10, 25, 47, 0.2) 0%, rgba(10, 25, 47, 0.8) 100%);
        z-index: 2;
        transition: opacity 0.5s ease;
    }

    .category-content {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 30px;
        z-index: 3;
        color: white;
        transform: translateY(60px); /* Đẩy nội dung xuống một chút */
        transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .category-icon {
        width: 45px;
        height: 45px;
        background: var(--gold-accent);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        font-size: 1.2rem;
        box-shadow: 0 8px 15px rgba(197, 160, 89, 0.3);
    }

    .category-name {
        font-weight: 800;
        font-size: 1.4rem;
        margin-bottom: 10px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .category-details {
        opacity: 0;
        transition: opacity 0.4s ease;
    }

        .category-details p {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.8);
            margin-bottom: 20px;
            line-height: 1.5;
        }

    .category-link {
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--gold-accent);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* HOVER EFFECTS */
    .category-luxury-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 50px rgba(10, 25, 47, 0.3);
    }

        .category-luxury-card:hover .category-image img {
            transform: scale(1.15); /* Phóng to ảnh nền */
        }

        .category-luxury-card:hover .category-content {
            transform: translateY(0); /* Đẩy nội dung lên */
        }

        .category-luxury-card:hover .category-details {
            opacity: 1; /* Hiện chi tiết */
        }

        .category-luxury-card:hover .category-overlay {
            background: linear-gradient(to bottom, rgba(197, 160, 89, 0.1) 0%, rgba(10, 25, 47, 0.95) 100%);
        }

    /* Mobile Tweak */
    @@media (max-width: 768px) {
        .category-content

    {
        transform: translateY(0);
    }

    .category-details {
        opacity: 1;
    }

    .category-luxury-card {
        height: 280px;
    }

    }
    /* CONTAINER CHO DẠNG LIST */
    .post-list-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .modern-post-list-item {
        display: grid;
        grid-template-columns: 280px 1fr; /* Tách ảnh và nội dung */
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

        .modern-post-list-item:hover {
            transform: translateX(8px); /* Hiệu ứng trượt nhẹ sang phải */
            box-shadow: 0 10px 25px rgba(10, 25, 47, 0.08);
            border-left: 4px solid var(--gold-accent);
        }

    /* THUMBNAIL TRONG LIST */
    .post-list-thumb {
        position: relative;
        height: 180px;
        overflow: hidden;
    }

        .post-list-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .modern-post-list-item:hover .post-list-thumb img {
        transform: scale(1.05);
    }

    .post-category-tag {
        position: absolute;
        top: 12px;
        left: 12px;
        background: var(--gold-accent);
        color: white;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* NỘI DUNG */
    .post-list-body {
        padding: 20px 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .post-list-meta {
        font-size: 0.8rem;
        color: var(--text-gray);
        margin-bottom: 10px;
        display: flex;
        gap: 15px;
    }

    .meta-item i {
        color: var(--gold-accent);
        margin-right: 5px;
    }

    .post-list-title {
        margin-bottom: 12px;
        line-height: 1.4;
    }

        .post-list-title a {
            color: var(--navy-dark);
            text-decoration: none;
            font-weight: 700;
            font-size: 1.25rem;
            transition: color 0.2s;
        }

            .post-list-title a:hover {
                color: var(--gold-accent);
            }

    .post-list-excerpt {
        color: #555;
        font-size: 0.95rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 15px;
    }

    .read-more-link {
        color: var(--navy-dark);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .read-more-link:hover {
            color: var(--gold-accent);
        }

    /* RESPONSIVE CHO MOBILE */
    @@media (max-width: 768px) {
        .modern-post-list-item

    {
        grid-template-columns: 1fr; /* Quay về dạng dọc trên mobile */
    }

    .post-list-thumb {
        height: 200px;
    }

    .post-list-body {
        padding: 20px;
    }

    }
    :root {
        --navy-dark: #0a192f;
        --navy-blue: #112240;
        --gold-accent: #c5a059;
        --text-gray: #8892b0;
        --bg-light: #f8f9fa;
    }

    body {
        background-color: var(--bg-body);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: #333;
    }

    /* 1. HERO & VIDEO */
    .hero-wrapper {
        position: relative;
        height: 80vh;
        min-height: 500px;
        overflow: hidden;
    }

    .hero-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-glass-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(10, 25, 47, 0.7) 0%, rgba(10, 25, 47, 0.9) 100%);
        display: flex;
        align-items: center;
        z-index: 2;
    }

    .hero-main-title {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 1.5rem;
    }

    .hero-divider {
        width: 80px;
        height: 4px;
        background: var(--gold-accent);
        margin: 1.5rem auto;
    }

    .bg-gold {
        background-color: var(--gold-accent);
        color: #fff;
    }

