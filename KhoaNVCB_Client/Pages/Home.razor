@page "/"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject PostService PostService
@inject CategoryService CategoryService

<PageTitle>Trang chủ - Khoa An ninh Nội bộ</PageTitle>

@* --- HERO SECTION HIỆN ĐẠI --- *@
<div class="hero-wrapper">
    <video autoplay loop muted playsinline class="hero-video" poster="/Images/Logo_hoc_vien_ANND.png" preload="metadata">
        <source src="/Images/video-nen-2.mp4" type="video/mp4">
    </video>
    <div class="hero-glass-overlay">
        <div class="container text-center text-white">
            <span class="badge rounded-pill bg-gold mb-3 px-3 py-2 text-uppercase fw-bold animate-fade-in">Học viện An ninh Nhân dân</span>
            <h1 class="hero-main-title">KHOA AN NINH CHÍNH TRỊ NỘI BỘ</h1>
            <div class="hero-divider"></div>
            <p class="hero-description">
                Nền tảng tri thức số chuyên biệt về nghiệp vụ bảo vệ chính trị nội bộ.
                Kết nối lý luận khoa học và thực tiễn chiến đấu.
            </p>
            <div class="mt-4 d-flex justify-content-center gap-3">
                <a href="/posts" class="btn btn-gold btn-lg px-4 fw-bold">Khám phá tài liệu</a>
            </div>
        </div>
    </div>
</div>

<div class="container mt-n5 position-relative z-index-3">
    @* --- STATS BAR --- *@
    <div class="row g-0 shadow-lg rounded-4 overflow-hidden bg-white text-center mb-5 border">
        <div class="col-md-4 p-4 border-end">
            <h3 class="fw-bold text-navy mb-0">1,200+</h3>
            <small class="text-muted text-uppercase fw-semibold">Tài liệu nghiên cứu </small>
        </div>
        <div class="col-md-4 p-4 border-end">
            <h3 class="fw-bold text-navy mb-0">50+</h3>
            <small class="text-muted text-uppercase fw-semibold">Giảng viên chuyên gia</small>
        </div>
        <div class="col-md-4 p-4">
            <h3 class="fw-bold text-navy mb-0">24/7</h3>
            <small class="text-muted text-uppercase fw-semibold">Truy cập trực tuyến</small>
        </div>
    </div>

    @* --- BÀI VIẾT NỔI BẬT --- *@
    <section id="featured-posts" class="mb-5">
        <div class="section-header d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="section-title text-navy fw-800">Tin tức nổi bật</h2>
                <div class="section-underline"></div>
            </div>
            <a href="/posts" class="view-all-link">Xem tất cả <i class="oi oi-arrow-right ms-1"></i></a>
        </div>

        @if (isLoading)
        {
            <div class="post-list-container">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton-loader-item mb-3">
                        <div class="skeleton-img"></div>
                        <div class="skeleton-text">
                            <div class="line"></div>
                            <div class="line short"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (recentPosts != null && recentPosts.Any())
        {
            <div class="post-list-container">
                @foreach (var post in recentPosts)
                {
                    <div class="modern-post-list-item">
                        <div class="post-list-thumb">
                            <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : post.ImageUrl)"
                                 alt="@post.Title" loading="lazy" />
                            <div class="post-category-tag">@(post.CategoryName ?? "Tin mới")</div>
                        </div>

                        <div class="post-list-body">
                            <div class="post-list-meta">
                                <span class="meta-item"><i class="oi oi-calendar me-1"></i> @post.CreatedDate?.ToString("dd/MM/yyyy")</span>
                                <span class="meta-item"><i class="oi oi-person me-1"></i> Ban Biên Tập</span>
                            </div>

                            <h4 class="post-list-title">
                                <a href="/post/@post.PostId">@post.Title</a>
                            </h4>

                            <p class="post-list-excerpt">
                                @(post.Summary ?? "Bản tin cập nhật những kiến thức mới nhất về công tác an ninh chính trị nội bộ và thực tiễn chiến đấu...")
                            </p>

                            <div class="post-list-footer">
                                <a href="/post/@post.PostId" class="read-more-link">
                                    Đọc chi tiết <i class="oi oi-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* --- CHUYÊN MỤC TÀI LIỆU --- *@
    <section class="mb-5 py-4">
        <div class="text-center mb-5">
            <h2 class="section-title mx-auto">Chuyên mục tài liệu</h2>
            <p class="text-muted">Hệ thống hóa tri thức theo từng mảng nghiệp vụ chuyên sâu</p>
        </div>

        @if (categories != null)
        {
            <div class="row g-4">
                @foreach (var cat in categories.Where(c => c.ParentId == null))
                {
                    <div class="col-lg-4 col-md-6">
                        <a href="/category/@cat.CategoryId" class="category-luxury-card">
                            <div class="category-image">
                                <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : cat.ImageUrl)" alt="@cat.CategoryName" />
                            </div>
                            <div class="category-overlay"></div>
                            <div class="category-content">
                                <h4 class="category-name">@cat.CategoryName</h4>
                                <div class="category-details">
                                    <p>Khám phá kho tài liệu nghiệp vụ chuyên sâu về @(cat.CategoryName?.ToLower() ?? "chuyên mục này").</p>
                                    <span class="category-link">Truy cập ngay <i class="oi oi-arrow-right ms-2"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </section>
</div>

@* --- SECTION: ĐỘI NGŨ GIẢNG VIÊN & CHUYÊN GIA --- *@
<section class="faculty-section py-5 px-3">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge rounded-pill bg-gold-light text-gold px-3 py-2 mb-2 fw-bold">NHÂN SỰ NÒNG CỐT</span>
            <h2 class="section-title mx-auto">Đội ngũ Giảng viên & Chuyên gia</h2>
            <div class="section-underline mx-auto"></div>
            <p class="text-muted mt-3">Hội tụ những nhà khoa học tâm huyết, kinh nghiệm thực tiễn và tư duy nghiệp vụ sắc bén</p>
        </div>

        <div class="row g-4">
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card">
                    <div class="faculty-image">
                        <img src="/Images/Logo_hoc_vien_ANND.png" alt="Giảng viên" />
                        <div class="faculty-socials">
                            <a href="#"><i class="oi oi-envelope-closed"></i></a>
                            <a href="#"><i class="oi oi-book"></i></a>
                        </div>
                    </div>
                    <div class="faculty-info text-center p-4">
                        <h5 class="faculty-name">PGS, TS. NGUYỄN VĂN A</h5>
                        <p class="faculty-rank">Giảng viên Cao cấp - Trưởng Khoa</p>
                        <hr class="short-hr mx-auto">
                        <p class="faculty-bio">Chuyên gia đầu ngành với hơn 25 năm kinh nghiệm nghiên cứu lý luận bảo vệ chính trị nội bộ.</p>
                        <div class="faculty-tags">
                            <span class="badge bg-light text-navy border">Lý luận</span>
                            <span class="badge bg-light text-navy border">Nghiệp vụ</span>
                        </div>
                    </div>
                </div>
            </div>
            @* Bạn có thể thêm Giảng viên 2, 3 tương tự *@
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="faculty-card h-100 d-flex flex-column justify-content-center align-items-center border-dashed p-4">
                    <div class="add-expert-circle mb-3">
                        <i class="oi oi-people"></i>
                    </div>
                    <h6 class="text-muted fw-bold">Và hơn 20 giảng viên</h6>
                    <p class="small text-center text-muted">Đang trực tiếp giảng dạy tại Khoa</p>
                    <a href="#" class="btn btn-sm btn-outline-gold mt-2">Xem danh sách đầy đủ</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* COPY TOÀN BỘ CSS GỐC CỦA BẠN VÀO ĐÂY */
    :root {
        --navy-primary: #0a192f;
        --navy-dark: #0a192f;
        --gold-accent: #c5a059;
        --gold-hover: #b08d4a;
        --text-muted: #64748b;
        --glass-white: rgba(255, 255, 255, 0.95);
    }

    .hero-wrapper {
        position: relative;
        height: 80vh;
        min-height: 500px;
        overflow: hidden;
    }

    .hero-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-glass-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(10, 25, 47, 0.7) 0%, rgba(10, 25, 47, 0.9) 100%);
        display: flex;
        align-items: center;
        z-index: 2;
    }

    .hero-main-title {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 1.5rem;
        color: white;
    }

    .hero-divider {
        width: 80px;
        height: 4px;
        background: var(--gold-accent);
        margin: 1.5rem auto;
    }

    .bg-gold {
        background-color: var(--gold-accent);
        color: #fff;
    }

    .btn-gold {
        background-color: var(--gold-accent);
        color: white;
        border-radius: 8px;
        transition: 0.3s;
    }

        .btn-gold:hover {
            background-color: #b08d4a;
            transform: translateY(-3px);
            color: #fff;
        }

    /* Post List Luxury Style */
    .post-list-container {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .modern-post-list-item {
        display: flex;
        background: var(--glass-white);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.03);
        transition: 0.4s;
        position: relative;
    }

        .modern-post-list-item:hover {
            transform: translateY(-5px) translateX(5px);
            box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.1);
            border-left: 5px solid var(--gold-accent);
        }

    .post-list-thumb {
        width: 280px;
        min-width: 280px;
        height: 190px;
        position: relative;
        overflow: hidden;
    }

        .post-list-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.6s;
        }

    .modern-post-list-item:hover .post-list-thumb img {
        transform: scale(1.1);
    }

    .post-category-tag {
        position: absolute;
        top: 15px;
        left: 15px;
        background: var(--gold-accent);
        color: white;
        padding: 4px 12px;
        font-size: 0.7rem;
        font-weight: 700;
        border-radius: 50px;
        z-index: 2;
    }

    .post-list-body {
        padding: 24px 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .post-list-title a {
        color: var(--navy-primary);
        text-decoration: none;
        font-weight: 700;
        font-size: 1.25rem;
    }

    .read-more-link {
        color: var(--gold-accent);
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        transition: 0.3s;
    }

    /* Category Card Luxury */
    .category-luxury-card {
        position: relative;
        display: block;
        height: 320px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        transition: 0.5s;
    }

    .category-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

        .category-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.8s;
        }

    .category-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(10, 25, 47, 0.2) 0%, rgba(10, 25, 47, 0.8) 100%);
        z-index: 2;
    }

    .category-content {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 30px;
        z-index: 3;
        color: white;
        transform: translateY(60px);
        transition: 0.5s;
    }

    .category-luxury-card:hover .category-content {
        transform: translateY(0);
    }

    .category-luxury-card:hover .category-details {
        opacity: 1;
    }

    .category-details {
        opacity: 0;
        transition: 0.4s;
    }

    /* Faculty Card */
    .faculty-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(10, 25, 47, 0.05);
        transition: 0.4s;
        height: 100%;
    }

    .faculty-image {
        position: relative;
        height: 250px;
        background: #f8f9fa;
    }

        .faculty-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 30px;
        }

    .faculty-name {
        color: #0a192f;
        font-weight: 800;
        font-size: 1rem;
    }

    .faculty-rank {
        color: #c5a059;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Utilities */
    .mt-n5 {
        margin-top: -3rem !important;
    }

    .text-navy {
        color: var(--navy-dark);
    }

    .z-index-3 {
        z-index: 3;
    }

    .section-title {
        font-weight: 800;
        color: var(--navy-dark);
        text-transform: uppercase;
    }

    .section-underline {
        width: 50px;
        height: 4px;
        background: var(--gold-accent);
        margin-top: 10px;
    }

    @@media (max-width: 768px) {
        .modern-post-list-item {
            flex-direction: column;
        }

        .post-list-thumb {
            width: 100%;
            height: 200px;
        }

        .mt-n5 {
            margin-top: -1rem !important;
        }

        .category-content {
            transform: translateY(0);
        }

        .category-details {
            opacity: 1;
        }
    }
</style>

@code {
    private List<PostDto>? recentPosts;
    private List<CategoryDto>? categories;
    private bool isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // TỐI ƯU TỐC ĐỘ: Gọi đúng hàm phân trang để lấy số lượng ít bài viết
                var categoriesTask = CategoryService.GetAllAsync();
                var postsTask = PostService.GetPagedPostsAsync(page: 1, pageSize: 3);

                await Task.WhenAll(categoriesTask, postsTask);

                categories = await categoriesTask;
                var result = await postsTask;
                recentPosts = result.Posts;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }
}