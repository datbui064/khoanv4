@page "/"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject PostService PostService
@inject CategoryService CategoryService

<PageTitle>Trang chủ - Khoa NV3</PageTitle>

@* --- PHẦN HERO VIDEO --- *@
@* --- PHẦN HERO VIDEO --- *@
<div class="hero-section">
    @* Thêm thuộc tính poster để hiện 1 bức ảnh mặc định trong lúc chờ tải video hoặc khi mạng yếu *@
    <video autoplay loop muted playsinline class="hero-video" poster="/Images/Logo_hoc_vien_ANND.png">
        @* Sửa lại src theo tên file mới (không dấu) *@
        <source src="/Images/hero-video.mp4" type="video/mp4">
        Trình duyệt của bạn không hỗ trợ thẻ video.
    </video>

    <div class="hero-overlay"></div>

    <div class="hero-content container">
        <h1 class="hero-title">KHOA AN NINH NỘI ĐỊA</h1>
        <p class="hero-subtitle">
            Cổng thông tin chuyên biệt, cung cấp các nghiên cứu, phân tích và tài liệu về an ninh nội địa Việt Nam. Nền tảng kết nối các chuyên gia, giảng viên và học viên.
        </p>
    </div>
</div>

<div class="container py-5">
    @* --- BÀI VIẾT NỔI BẬT --- *@
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
            <h4 class="fw-bold text-uppercase m-0 text-dark border-start border-danger border-4 ps-2">Bài viết nổi bật</h4>
        </div>

        @if (recentPosts == null)
        {
            <div class="text-center py-3"><div class="spinner-border text-danger" role="status"></div></div>
        }
        else if (recentPosts.Any())
        {
            <div class="horizontal-scroll-container d-flex gap-4 pb-3">
                @foreach (var post in recentPosts)
                {
                    @* Đã thay thế style="width: 300px;" bằng class="custom-card-width" *@
                    <div class="card shadow-sm border-0 rounded-3 flex-shrink-0 card-hover custom-card-width">
                        <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : post.ImageUrl)"
                             class="card-img-top" alt="@post.Title" style="height: 160px; object-fit: cover;" />
                        <div class="card-body p-3 d-flex flex-column">
                            <span class="badge bg-danger mb-2 align-self-start" style="font-size: 0.7rem;">@(post.CategoryName ?? "Mới")</span>
                            <a href="/post/@post.PostId" class="text-decoration-none stretched-link">
                                <h6 class="fw-bold text-dark hover-danger text-truncate-2">@post.Title</h6>
                            </a>
                            <small class="text-muted mt-auto pt-2"><i class="oi oi-clock me-1"></i> @post.CreatedDate?.ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* --- DANH SÁCH CHUYÊN MỤC --- *@
    <div>
        <div class="text-center mb-4 pt-4">
            <h3 class="fw-bold text-uppercase text-dark">CHUYÊN MỤC</h3>
        </div>

        @if (categories == null)
        {
            <div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var cat in categories.Where(c => c.ParentId == null))
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="category-card rounded-3 shadow-sm overflow-hidden position-relative" style="height: 200px;">
                            <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : cat.ImageUrl)"
                                 class="w-100 h-100" style="object-fit: cover;"
                                 alt="@cat.CategoryName" />
                            <div class="overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.4); z-index: 1;"></div>
                            <div class="position-absolute top-50 start-50 translate-middle w-100 text-center" style="z-index: 2;">
                                <a href="/category/@cat.CategoryId" class="text-decoration-none stretched-link text-white fw-bold text-uppercase fs-5 category-title">
                                    @cat.CategoryName
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* --- PHẦN GIỚI THIỆU TÍNH NĂNG --- *@
    <div class="row align-items-center mt-5 pt-5">
        <div class="col-lg-6 mb-4 mb-lg-0 text-center">
            <img src="/Images/h1-8108.png" alt="Học tập trực tuyến" class="img-fluid rounded-4 shadow-lg" />
        </div>
        <div class="col-lg-6">
            <div class="d-flex flex-column gap-4">
                <div class="feature-box p-4 rounded-4 bg-white border">
                    <i class="oi oi-book fs-3 mb-2 text-danger"></i>
                    <h5 class="fw-bold">Học tập mọi lúc, mọi nơi</h5>
                    <p class="text-muted mb-0 small">Nền tảng giúp học viên chủ động tiếp cận bài giảng, tài liệu đào tạo mọi lúc, mọi nơi.</p>
                </div>
                <div class="feature-box p-4 rounded-4 bg-white border">
                    <i class="oi oi-people fs-3 mb-2 text-danger"></i>
                    <h5 class="fw-bold">Giảng viên nhiệt huyết</h5>
                    <p class="text-muted mb-0 small">Đội ngũ giảng viên Khoa trực tiếp hướng dẫn, bảo đảm tính khoa học và thực tiễn.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* 1. HERO SECTION */
    .hero-section {
        position: relative;
        width: 100%;
        height: 65vh;
        min-height: 400px;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        border-bottom: 3px solid #b71c1c;
    }

    .hero-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: white;
        padding: 0 15px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    .hero-subtitle {
        font-size: 1.3rem;
        max-width: 800px;
        margin: 0 auto;
        opacity: 0.9;
        line-height: 1.6;
    }

    /* 2. SCROLL NGANG */
    .horizontal-scroll-container {
        overflow-x: auto;
        white-space: nowrap;
        padding-bottom: 10px;
        scroll-snap-type: x mandatory; /* Giúp vuốt trên mobile mượt hơn */
    }

        .horizontal-scroll-container::-webkit-scrollbar {
            height: 6px;
        }

        .horizontal-scroll-container::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

    /* 3. CARDS & HOVER */
    .card-hover {
        transition: transform 0.3s ease;
        scroll-snap-align: start; /* Căn chỉnh card khi vuốt */
    }

        .card-hover:hover {
            transform: translateY(-8px);
        }

    /* Kích thước Card tùy chỉnh cho cả máy tính và điện thoại */
    .custom-card-width {
        width: 300px;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        white-space: normal;
        word-break: break-word;
        line-height: 1.4;
        height: 2.8em;
    }

    .category-card {
        transition: transform 0.3s;
        cursor: pointer;
    }

        .category-card:hover {
            transform: scale(1.02);
        }

    .category-title {
        text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    }

    .feature-box {
        transition: all 0.3s ease;
    }

        .feature-box:hover {
            transform: translateX(10px);
            border-color: #dc3545 !important;
        }

    /* --- RESPONSIVE CHO MÀN HÌNH NHỎ (MOBILE) --- */
    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2.2rem;
        }

        .hero-subtitle {
            font-size: 1rem;
        }
    }

    @@media (max-width: 576px) {
        /* Trên điện thoại, card chiếm 80% màn hình để chừa 1 khoảng cho card tiếp theo (gợi ý vuốt) */
        .custom-card-width {
            width: 80vw;
        }
    }
</style>

@code {
    private List<PostDto>? recentPosts;
    private List<CategoryDto>? categories;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await CategoryService.GetAllAsync();
            var allPosts = await PostService.GetAllAsync();
            if (allPosts != null)
            {
                recentPosts = allPosts.Where(p => p.Status == "Published").OrderByDescending(p => p.CreatedDate).Take(6).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}