@page "/login"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous] 
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="login-page-wrapper">
    <div class="login-box-container">
        @* Cột trái: Hình ảnh/Logo trang trọng *@
        <div class="login-brand-side d-none d-lg-flex">
            <div class="brand-content text-center text-white">
                <img src="/Images/Logo_hoc_vien_ANND.png" class="brand-logo-main mb-4" alt="Logo">
                <h4 class="fw-bold">HỆ THỐNG QUẢN TRỊ</h4>
                <p class="small opacity-75">Khoa An ninh Chính trị Nội bộ</p>
                <div class="brand-divider"></div>
                <p class="brand-slogan text-gold">Bảo vệ Đảng - Bảo vệ Chế độ - Bảo vệ Nhân dân</p>
            </div>
        </div>

        @* Cột phải: Form đăng nhập *@
        <div class="login-form-side p-4 p-md-5">
            <div class="form-header mb-4 text-center text-lg-start">
                <h3 class="fw-800 text-navy mb-1">ĐĂNG NHẬP</h3>
                <p class="text-muted small">Chào mừng bạn quay trở lại hệ thống.</p>
            </div>

            <div class="custom-input-group mb-3">
                <label class="form-label-custom"><i class="fa-solid fa-user-shield me-2"></i>Tên đăng nhập</label>
                <div class="input-with-icon">
                    <input class="form-control-custom" @bind="loginModel.Username" placeholder="Nhập tên đăng nhập..." />
                </div>
            </div>

            <div class="custom-input-group mb-4">
                <label class="form-label-custom"><i class="fa-solid fa-lock me-2"></i>Mật khẩu</label>
                <div class="input-with-icon">
                    <input type="password" class="form-control-custom" @bind="loginModel.Password" placeholder="••••••••" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-modern mb-4">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> @errorMessage
                </div>
            }

            <button class="btn-login-gold w-100 mb-4" @onclick="HandleLogin" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span> <span>Đang xác thực...</span>
                }
                else
                {
                    <span>TRUY CẬP HỆ THỐNG <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i></span>
                }
            </button>

            <div class="text-center">
                <p class="text-muted small">
                    Chưa có tài khoản?
                    <a href="/register" class="link-gold fw-bold text-decoration-none ms-1">Đăng ký thành viên</a>
                </p>
                <a href="/" class="text-decoration-none text-muted x-small mt-2 d-block hover-navy">
                    <i class="fa-solid fa-house-chimney me-1"></i> Quay về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? returnUrl { get; set; }
    private LoginDto loginModel = new();
    private string? errorMessage;
    private bool isProcessing = false;

    private async Task HandleLogin()
    {
        isProcessing = true;
        errorMessage = null;

        var success = await AuthService.Login(loginModel);
        if (success)
        {
            // NẾU CÓ returnUrl THÌ QUAY LẠI ĐÓ, KHÔNG THÌ MỚI VỀ TRANG CHỦ
            if (!string.IsNullOrEmpty(returnUrl))
            {
                Nav.NavigateTo(returnUrl);
            }
            else
            {
                Nav.NavigateTo("/");
            }
        }
        else
        {
            errorMessage = "Sai tài khoản hoặc mật khẩu";
        }
        isProcessing = false;
    }
}
<style>
    :root {
        --navy-deep: #0a192f;
        --gold-primary: #c5a059;
        --gold-hover: #b08d4a;
    }

    .login-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #050c18 0%, #112240 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .login-box-container {
        width: 100%;
        max-width: 1000px;
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }

    /* Cột thương hiệu */
    .login-brand-side {
        width: 45%;
        background: linear-gradient(rgba(10, 25, 47, 0.85), rgba(10, 25, 47, 0.85)), url('https://source.unsplash.com/random/800x1200/?security,building'); /* Bạn có thể thay bằng ảnh HV ANND */
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        border-right: 4px solid var(--gold-primary);
    }

    .brand-logo-main {
        width: 100px;
        filter: drop-shadow(0 0 15px rgba(197, 160, 89, 0.5));
    }

    .brand-divider {
        width: 50px;
        height: 2px;
        background: var(--gold-primary);
        margin: 20px auto;
    }

    .text-gold {
        color: var(--gold-primary);
    }

    /* Form Đăng nhập */
    .login-form-side {
        flex: 1;
        background: #fff;
    }

    .fw-800 {
        font-weight: 800;
    }

    .text-navy {
        color: var(--navy-deep);
    }

    .form-label-custom {
        font-size: 0.85rem;
        font-weight: 600;
        color: #444;
        margin-bottom: 8px;
        display: block;
    }

    .form-control-custom {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        background: #f8f9fa;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            outline: none;
            border-color: var(--gold-primary);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
        }

    /* Alert hiện đại */
    .alert-modern {
        background: #fff5f5;
        color: #e53e3e;
        padding: 12px;
        border-radius: 10px;
        border-left: 4px solid #e53e3e;
        font-size: 0.85rem;
    }

    /* Nút đăng nhập Gold */
    .btn-login-gold {
        background: var(--gold-primary);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-transform: uppercase;
    }

        .btn-login-gold:hover:not(:disabled) {
            background: var(--gold-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(197, 160, 89, 0.3);
        }

        .btn-login-gold:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .link-gold {
        color: var(--gold-primary);
        transition: 0.3s;
    }

        .link-gold:hover {
            color: var(--navy-deep);
        }

    .hover-navy:hover {
        color: var(--navy-deep) !important;
    }

    .x-small {
        font-size: 0.75rem;
    }

    /* Mobile Responsive */
    @@media (max-width: 992px) {
        .login-box-container

    {
        max-width: 500px;
    }

    .login-form-side {
        padding: 40px 30px;
    }

    }</style>