﻿
@page "/posts"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@inject PostService PostService
@inject CategoryService CategoryService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Kho Lưu Trữ - Khoa NV4</PageTitle>

<div class="user-content-wrapper py-4">
    <div class="container">
        @* --- TIÊU ĐỀ TRANG (Thu nhỏ lại) --- *@
        <div class="header-section mb-4 animate-fade-in">
            <h4 class="fw-bold text-navy-blue mb-1">KHO LƯU TRỮ BÀI VIẾT</h4>
            <div class="bg-danger" style="height: 3px; width: 40px;"></div>
        </div>

        @* --- THANH LỌC (Gọn gàng như Admin) --- *@
        <div class="filter-bar bg-white p-3 mb-4 rounded-3 shadow-sm border">
            <div class="row g-2 align-items-center">
                <div class="col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-start-0" placeholder="Tìm tiêu đề..."
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="ApplyFilter" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-sm" @bind="selectedCategory" @bind:after="ApplyFilter">
                        <option value="">Tất cả chuyên mục</option>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.CategoryName">@cat.CategoryName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" @bind="sortBy" @bind:after="ApplyFilter">
                        <option value="newest">Mới nhất</option>
                        <option value="title-az">Tiêu đề (A-Z)</option>
                    </select>
                </div>
            </div>
        </div>

        @* --- BẢNG DANH SÁCH THU GỌN --- *@
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light" style="font-size: 0.8rem;">
                        <tr>
                            <th class="ps-3" style="width: 80px;">ẢNH</th>
                            <th>NỘI DUNG</th>
                            <th style="width: 150px;">CHUYÊN MỤC</th>
                            <th class="text-end pe-3" style="width: 120px;">NGÀY</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr><td colspan="4" class="text-center py-5"><div class="spinner-border spinner-border-sm text-danger"></div></td></tr>
                        }
                        else if (!pagedPosts.Any())
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">Không tìm thấy bài viết nào.</td></tr>
                        }
                        else
                        {
                            @foreach (var post in pagedPosts)
                            {
                                <tr @onclick='() => Nav.NavigateTo($"/post/{post.PostId}")' style="cursor: pointer;">
                                    <td class="ps-3">
                                        <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/Images/Logo_hoc_vien_ANND.png" : post.ImageUrl)"
                                             class="rounded border"
                                             style="width: 60px; height: 40px; object-fit: cover;" />
                                    </td>
                                    <td>
                                        <div class="fw-bold text-navy-blue text-truncate mb-0" style="max-width: 500px; font-size: 0.95rem;">@post.Title</div>
                                        <div class="small text-muted text-truncate" style="max-width: 500px;">@post.Summary</div>
                                    </td>
                                    <td><span class="badge bg-gold-soft text-gold">@post.CategoryName</span></td>
                                    <td class="text-end pe-3 small text-muted">@post.CreatedDate?.ToString("##/##/####")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @* --- NÚT TẢI THÊM (LOAD MORE) --- *@
            @if (currentPage < totalPages)
            {
                <div class="card-footer bg-white text-center py-4 border-top-0">
                    <button class="btn btn-outline-primary fw-bold px-4 rounded-pill shadow-sm"
                            style="transition: all 0.3s;"
                            @onclick="LoadMore" disabled="@isLoadingMore">
                        
                        @if (isLoadingMore)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>ĐANG TẢI...</span>
                        }
                        else
                        {
                            <span>TẢI THÊM BÀI VIẾT</span>
                            <i class="bi bi-chevron-down ms-2"></i>
                        }
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --navy-blue: #1a237e;
        --gold-bg: #fff9c4;
        --gold-text: #856404;
    }

    /* Hiệu ứng giống Admin */
    .table tbody tr {
        transition: all 0.2s;
        border-bottom: 1px solid #f1f1f1;
    }

        .table tbody tr:hover {
            background-color: rgba(26, 35, 126, 0.05) !important;
            transform: scale(1.001);
            box-shadow: inset 3px 0 0 #dc3545;
        }

    .bg-gold-soft {
        background-color: var(--gold-bg);
        color: var(--gold-text);
        font-size: 0.7rem;
        padding: 4px 8px;
    }

    .text-navy-blue {
        color: var(--navy-blue);
    }

    /* Fix text bị tràn */
    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "Published";
    
    private List<PostListItemDto> pagedPosts = new();
    private List<CategoryDto> categories = new();
    
    // Hai trạng thái loading khác biệt
    private bool isLoading = true;       // Dùng khi load mới toàn trang
    private bool isLoadingMore = false;  // Dùng khi bấm nút Tải thêm

    private string searchTerm = "";
    private string selectedCategory = "";
    private string sortBy = "newest";

    private int currentPage = 1;
    private int pageSize = 5; // Cập nhật hiển thị 5 bài/lượt theo ý bạn
    private int totalPages = 1;
    private int totalPostsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var cats = await CategoryService.GetAllAsync();
        if (cats != null)
        {
            categories = cats;
        }
        await LoadData(isLoadMore: false);
    }

    // Hàm LoadData giờ nhận thêm tham số để phân biệt hành động
    private async Task LoadData(bool isLoadMore = false)
    {
        if (isLoadMore)
        {
            isLoadingMore = true;
            currentPage++; // Tăng trang lên 1
        }
        else
        {
            isLoading = true;
            currentPage = 1; // Reset về trang đầu
        }
        StateHasChanged();

        try
        {
            var result = await PostService.GetPublicPostsPagedAsync(
    currentPage, pageSize, searchTerm, selectedCategory, sortBy);

            if (result != null)
            {
                if (isLoadMore)
                {
                    // NẾU TẢI THÊM: Cộng dồn dữ liệu mới vào cuối danh sách hiện tại
                    pagedPosts.AddRange(result.Items);
                }
                else
                {
                    // NẾU TÌM KIẾM/ĐỔI TAB: Thay thế hoàn toàn danh sách cũ
                    pagedPosts = result.Items;
                }
                
                totalPages = result.TotalPages;
                totalPostsCount = result.TotalCount;
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.log", ex.Message);
        }
        finally
        {
            isLoading = false;
            isLoadingMore = false;
            StateHasChanged();
        }
    }

    // Sự kiện bấm nút Tải thêm
    private async Task LoadMore()
    {
        await LoadData(isLoadMore: true);
    }

    private async Task ApplyFilter()
    {
        // Khi gõ tìm kiếm hoặc lọc chuyên mục -> Tải lại từ trang 1
        await LoadData(isLoadMore: false);
    }

    private async Task SwitchTab(string tabName)
    {
        if (activeTab == tabName) return;
        activeTab = tabName;
        await LoadData(isLoadMore: false);
    }

    private async Task RefreshData() => await LoadData(isLoadMore: false);

    private void EditPost(int id) => Nav.NavigateTo($"/admin/posts/edit/{id}");

    private async Task DeletePost(int id, string title)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Xóa bài viết: {title}?");
        if (confirm)
        {
            var success = await PostService.DeleteAsync(id);
            if (success) await LoadData(isLoadMore: false);
        }
    }
}