﻿
@page "/practice/{categoryId:int}/{count:int}/{minutes:int}"
@using System.Text.Json
@attribute [AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Đang ôn tập: @categoryName</PageTitle>

<div class="container py-4" style="max-width: 900px;">
    @if (isLoading)
    {
        <div class="text-center py-5 mt-5">
            <div class="spinner-grow text-success" style="width: 3rem; height: 3rem;" role="status"></div>
            <h4 class="mt-4 text-secondary fw-light">Đang khởi tạo bộ đề ngẫu nhiên...</h4>
        </div>
    }
    else if (questions == null || !questions.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <i class="bi bi-exclamation-triangle text-warning display-1 mb-4"></i>
            <h4 class="fw-bold">Rất tiếc, không tìm thấy câu hỏi!</h4>
            <p class="text-muted">Chủ đề này hiện chưa có dữ liệu hoặc đã xảy ra lỗi.</p>
            <div class="mt-3">
                <a href="/" class="btn btn-dark px-4 rounded-pill">Quay lại trang chủ</a>
            </div>
        </div>
    }
    else if (!isFinished)
    {
        @* PROGRESS & TIMER HEADER *@
        <div class="sticky-top bg-white pt-2 pb-3 shadow-sm mb-4" style="z-index: 1020; margin-top: -1.5rem;">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-dark-subtle text-dark px-3 py-2 rounded-pill fw-bold">
                        CÂU @(currentIndex + 1) / @questions.Count
                    </span>
                    <div class="d-flex align-items-center bg-light px-3 py-2 rounded-pill border @(timeLeft < 60 ? "text-danger animate-pulse" : "text-primary")">
                        <i class="bi bi-stopwatch-fill me-2"></i>
                        <span class="fw-mono fs-5 fw-bold">@FormatTime(timeLeft)</span>
                    </div>
                </div>
                <div class="progress" style="height: 6px; border-radius: 10px;">
                    <div class="progress-bar bg-success transition-all"
                         style="width: @((currentIndex + 1) * 100 / questions.Count)%"></div>
                </div>
            </div>
        </div>

        @* QUESTION CARD *@
        <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <span class="text-uppercase text-muted small fw-bold tracking-wider">Câu hỏi hiện tại</span>
                    <h3 class="fw-bold text-dark mt-2 lh-base">@questions[currentIndex].GetProperty("content").GetString()</h3>
                </div>

                <div class="row g-3">
                    @foreach (var opt in new[] { "A", "B", "C", "D" })
                    {
                        var optionLetter = opt;
                        var optionText = questions[currentIndex].GetProperty($"option{opt}").GetString();
                        var qId = questions[currentIndex].GetProperty("questionId").GetInt32();
                        var isAnswered = userAnswers.ContainsKey(qId);

                        <div class="col-12">
                            <button class="btn @GetOptionClass(qId, optionLetter) w-100 text-start p-3 p-md-4 rounded-4 border-2 transition-all d-flex align-items-center"
                                    @onclick='() => SelectAnswer(qId, optionLetter)'
                                    disabled="@isAnswered">
                                <span class="option-badge me-3">@optionLetter</span>
                                <span class="flex-grow-1 fs-5 fw-medium">@optionText</span>

                                @if (isAnswered)
                                {
                                    var correct = questions[currentIndex].GetProperty("correctAnswer").GetString();
                                    if (optionLetter == correct)
                                    {
                                        <i class="bi bi-check-circle-fill fs-3 text-success"></i>
                                    }
                                    else if (userAnswers[qId] == optionLetter)
                                    {
                                        <i class="bi bi-x-circle-fill fs-3 text-danger"></i>
                                    }
                                }
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* NAVIGATION *@
        <div class="d-flex justify-content-between align-items-center mb-5">
            <button class="btn btn-link text-decoration-none text-dark fw-bold" @onclick="Prev" disabled="@(currentIndex == 0)">
                <i class="bi bi-arrow-left me-2"></i> Câu trước
            </button>

            @if (currentIndex < questions.Count - 1)
            {
                <button class="btn btn-dark btn-lg px-5 rounded-pill shadow" @onclick="Next">
                    Tiếp theo <i class="bi bi-arrow-right ms-2"></i>
                </button>
            }
            else
            {
                <button class="btn btn-success btn-lg px-5 rounded-pill shadow animate-bounce" @onclick="Finish">
                    HOÀN THÀNH <i class="bi bi-flag-fill ms-2"></i>
                </button>
            }
        </div>
    }
    else
    {
        @* RESULT PAGE *@
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden mt-5">
            <div class="p-5 text-center bg-dark text-white">
                <div class="mb-3">
                    @if (score >= questions.Count / 2)
                    {
                        <i class="bi bi-trophy-fill text-warning display-1"></i>
                    }
                    else
                    {
                        <i class="bi bi-emoji-smile text-info display-1"></i>
                    }
                </div>
                <h2 class="fw-bold">KẾT QUẢ ÔN TẬP</h2>
                <p class="opacity-50">Bạn đã hoàn thành bài luyện tập của mình</p>
            </div>
            <div class="card-body p-5 text-center">
                <div class="row justify-content-center">
                    <div class="col-md-4 mb-4">
                        <div class="p-4 bg-light rounded-4 border">
                            <div class="display-4 fw-bold text-primary">@score/@questions.Count</div>
                            <div class="small fw-bold text-uppercase text-muted">Số câu đúng</div>
                        </div>
                    </div>
                    
                </div>

            

                @* --- THÊM MỚI: PHẦN CHI TIẾT BÀI LÀM --- *@
                <div class="mt-5 text-start">
                    <h4 class="fw-bold mb-4 border-bottom pb-3 text-navy-blue">
                        <i class="bi bi-card-checklist me-2"></i>Chi Tiết Bài Làm
                    </h4>
                    
                    @for (int i = 0; i < questions.Count; i++)
                    {
                        var q = questions[i];
                        var qId = q.GetProperty("questionId").GetInt32();
                        var correctAns = q.GetProperty("correctAnswer").GetString();
                        
                        // Lấy đáp án người dùng chọn (sẽ là null nếu người dùng bỏ qua không chọn)
                        userAnswers.TryGetValue(qId, out var userAns);

                        <div class="card mb-4 border-0 shadow-sm rounded-4 bg-light">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 lh-base">
                                    <span class="badge bg-dark me-2">Câu @(i + 1)</span>
                                    @q.GetProperty("content").GetString()
                                </h5>

                                <div class="d-flex flex-column gap-2">
                                    @foreach (var opt in new[] { "A", "B", "C", "D" })
                                    {
                                        var optText = q.GetProperty($"option{opt}").GetString();
                                        
                                        var isCorrect = (opt == correctAns);
                                        var isUserChoice = (opt == userAns);

                                        // Thiết lập màu sắc mặc định
                                        string bgClass = "bg-white text-dark border-secondary-subtle";
                                        string icon = "";

                                        // Nếu đây là đáp án đúng -> Bôi xanh lá
                                        if (isCorrect)
                                        {
                                            bgClass = "bg-success-subtle text-success border-success fw-bold";
                                            icon = "<i class='bi bi-check-circle-fill float-end fs-5'></i>";
                                        }
                                        // Nếu đây là đáp án người dùng chọn sai -> Bôi đỏ
                                        else if (isUserChoice && !isCorrect)
                                        {
                                            bgClass = "bg-danger-subtle text-danger border-danger fw-bold";
                                            icon = "<i class='bi bi-x-circle-fill float-end fs-5'></i>";
                                        }

                                        <div class="p-3 rounded-3 border @bgClass">
                                            <span class="fw-bold me-2">@opt:</span> @optText
                                            @((MarkupString)icon)
                                        </div>
                                    }
                                </div>
                                
                                @* Thông báo nếu bỏ trống *@
                                @if (string.IsNullOrEmpty(userAns))
                                {
                                    <div class="mt-3 text-warning fw-bold small">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> Bạn đã bỏ qua câu hỏi này.
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                @* --- KẾT THÚC PHẦN CHI TIẾT --- *@

                <div class="mt-4 d-flex gap-2 justify-content-center">
                    <button class="btn btn-primary btn-lg px-4 rounded-pill" @onclick="Restart">
                        Luyện tập lại
                    </button>
                    <a href="/" class="btn btn-outline-dark btn-lg px-4 rounded-pill">
                        Về trang chủ
                    </a>
                </div>

            </div>
        </div>
    }
</div>

<style>
    body {
        background-color: #f8fafc;
        color: #1e293b;
    }

    .transition-all {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .option-badge {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
        border-radius: 10px;
        font-weight: 800;
        color: #64748b;
    }

    .btn-outline-dark {
        border-color: #e2e8f0;
        background: white;
    }

        .btn-outline-dark:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
            color: #1e293b;
        }

    /* Trạng thái đáp án */
    .btn-correct {
        background-color: #ecfdf5 !important;
        border-color: #10b981 !important;
        color: #065f46 !important;
    }

        .btn-correct .option-badge {
            background: #10b981;
            color: white;
        }

    .btn-wrong {
        background-color: #fef2f2 !important;
        border-color: #ef4444 !important;
        color: #991b1b !important;
    }

        .btn-wrong .option-badge {
            background: #ef4444;
            color: white;
        }

    .opacity-50 {
        opacity: 0.5;
    }

    .fw-mono {
        font-family: 'Courier New', Courier, monospace;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }
    }

    .animate-pulse {
        animation: pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
</style>

@code {
    [Parameter] public int categoryId { get; set; }
    [Parameter] public int count { get; set; }

    private List<JsonElement> questions = new();
    private Dictionary<int, string> userAnswers = new();
    private int currentIndex = 0;
    private bool isLoading = true;
    private bool isFinished = false;
    private string categoryName = "";
    private int score = 0;
    [Parameter] public int minutes { get; set; } // Tham số thời gian mới
    private int timeLeft;
    private Timer? timer;
    // THÊM 3 BIẾN NÀY
    private string fullName = "Khách";
    private string studentId = "N/A";
    private string className = "N/A";
    protected override async Task OnInitializedAsync()
    {
        timeLeft = minutes * 60; // Chuyển phút sang giây
        await LoadQuestions();
        StartTimer();
    }

    // THÊM HÀM NÀY ĐỂ MÓC DỮ LIỆU TỪ TRÌNH DUYỆT
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var name = await JS.InvokeAsync<string>("sessionStorage.getItem", "p_fullName");
                if (!string.IsNullOrEmpty(name)) fullName = name;

                var msv = await JS.InvokeAsync<string>("sessionStorage.getItem", "p_studentId");
                if (!string.IsNullOrEmpty(msv)) studentId = msv;

                var lop = await JS.InvokeAsync<string>("sessionStorage.getItem", "p_className");
                if (!string.IsNullOrEmpty(lop)) className = lop;
            }
            catch { /* Bỏ qua nếu lỗi */ }
        }
    }

    private void StartTimer()
    {
        timer = new Timer(_ =>
        {
            if (timeLeft > 0 && !isFinished)
            {
                timeLeft--;
                InvokeAsync(StateHasChanged);
            }
            else if (timeLeft <= 0)
            {
                InvokeAsync(Finish);
            }
        }, null, 1000, 1000);
    }

    private string FormatTime(int seconds)
    {
        var m = seconds / 60;
        var s = seconds % 60;
        return $"{m:00}:{s:00}";
    }

    private async Task LoadQuestions()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>($"api/Quizzes/practice/{categoryId}/{count}");
            categoryName = response.GetProperty("categoryName").GetString() ?? "Chủ đề";
            questions = response.GetProperty("questions").EnumerateArray().ToList();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; }
    }

    private void SelectAnswer(int qId, string option)
    {
        if (!userAnswers.ContainsKey(qId) && timeLeft > 0)
        {
            userAnswers[qId] = option;
            var correct = questions[currentIndex].GetProperty("correctAnswer").GetString();
            if (option == correct) score++;
        }
    }


    private string GetOptionClass(int qId, string option)
    {
        if (!userAnswers.ContainsKey(qId)) return "btn-outline-dark shadow-sm";

        var correct = questions.FirstOrDefault(q => q.GetProperty("questionId").GetInt32() == qId)
                               .GetProperty("correctAnswer").GetString();

        if (option == correct) return "btn-correct";
        if (userAnswers[qId] == option && option != correct) return "btn-wrong";

        return "btn-outline-dark opacity-50";
    }

    private void Next() => currentIndex++;
    private void Prev() => currentIndex--;
    private async Task Finish() // Đổi thành async Task
    {
        if (isFinished) return; // Tránh nộp 2 lần
        
        isFinished = true;
        timer?.Dispose();
        StateHasChanged(); // Hiện điểm cho người dùng xem ngay lập tức

        // Tạo cục dữ liệu nộp bài (SessionId = null)
        var request = new SubmitQuizRequest
        {
            SessionId = null,
            CategoryId = categoryId,
            FullName = fullName,
            StudentIdOrEmail = studentId,
            ClassName = className,
            Answers = userAnswers
        };

        try
        {
            // Bắn dữ liệu về Server
            await Http.PostAsJsonAsync("api/Quizzes/submit", request);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi nộp bài: {ex.Message}");
        }
    }
    private void Restart() => Navigation.NavigateTo(Navigation.Uri, forceLoad: true);

    public void Dispose() => timer?.Dispose();

    // THÊM CLASS NÀY Ở CUỐI CÙNG
    public class SubmitQuizRequest
    {
        public int? SessionId { get; set; } // Dấu ? cho phép null
        public int CategoryId { get; set; }
        public string FullName { get; set; } = null!;
        public string StudentIdOrEmail { get; set; } = null!;
        public string ClassName { get; set; } = null!;
        public Dictionary<int, string> Answers { get; set; } = new();
    }
}