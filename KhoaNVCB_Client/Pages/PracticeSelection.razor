@page "/practice-setup"
@attribute [AllowAnonymous]
@using KhoaNVCB_Client.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS

<style>
    :root {
        --brand-primary: #0f172a;
        --brand-accent: #10b981;
        --brand-bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    .practice-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 30px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .custom-header {
        background: var(--brand-primary);
        padding: 2.5rem 2rem;
        position: relative;
    }

        /* Hiệu ứng hạt chìm cho Header */
        .custom-header::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 20px 20px;
        }

    /* Style chung cho Radio Buttons (Số câu & Thời gian) */
    .option-selector .btn-check + .btn {
        background: #ffffff;
        border: 1.5px solid #edf2f7;
        color: var(--text-main);
        border-radius: 16px;
        padding: 1rem 0.5rem;
        transition: all 0.25s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .option-selector .btn-check:checked + .btn {
        background: #ecfdf5;
        border-color: var(--brand-accent);
        color: var(--brand-accent);
        font-weight: 700;
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -5px rgba(16, 185, 129, 0.2);
    }

    .custom-select {
        background-color: #f8fafc !important;
        border: 1.5px solid #edf2f7 !important;
        border-radius: 14px !important;
        padding: 0.75rem 1rem !important;
    }

    .btn-start {
        background: var(--brand-accent);
        color: white;
        font-weight: 700;
        border-radius: 18px;
        padding: 1.2rem;
        border: none;
        box-shadow: 0 10px 20px -5px rgba(16, 185, 129, 0.4);
        transition: all 0.3s ease;
    }

        .btn-start:hover {
            background: #059669;
            transform: scale(1.02);
        }

    .section-title {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--text-muted);
        margin-bottom: 1rem;
        display: block;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card practice-card">
                <div class="custom-header text-center text-white">
                    <div class="mb-2">
                        <i class="bi bi-ui-checks text-success fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Cài đặt ôn tập</h3>
                    <p class="small opacity-50 mb-0">Cùng nhau ôn luyện nào!!!</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (categories == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-success" role="status"></div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <label class="section-title">Thông tin của bạn</label>
                            <input type="text" class="form-control mb-2 custom-select" @bind="fullName" placeholder="Họ và tên (Bắt buộc)" />
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="text" class="form-control custom-select" @bind="studentId" placeholder="Mã SV / Email" />
                                </div>
                                <div class="col-6">
                                    <input type="text" class="form-control custom-select" @bind="className" placeholder="Lớp" />
                                </div>
                            </div>
                            @if (showValidationError)
                            {
                                <small class="text-danger mt-1 d-block"><i class="bi bi-exclamation-circle"></i> Vui lòng nhập ít nhất Họ và Tên!</small>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="section-title">1. Chủ đề ôn tập</label>
                            <select class="form-select form-select-lg custom-select shadow-none" @bind="selectedCategoryId">
                                <option value="0">Tất cả danh mục kiến thức</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="section-title">2. Số lượng câu hỏi</label>
                            <div class="row g-2 option-selector">
                                @foreach (var num in new[] { 10, 20, 30, 50 })
                                {
                                    <div class="col-3">
                                        <input type="radio" class="btn-check" name="countOptions" id="count-@num"
                                               value="@num" checked="@(selectedCount == num)"
                                               @onclick="() => selectedCount = num">
                                            <label class="btn w-100" for="count-@num">
                                                <span class="fs-5">@num</span>
                                                <span style="font-size: 0.6rem; opacity: 0.7;">CÂU</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="section-title">3. Thời gian giới hạn</label>
                                <div class="row g-2 option-selector">
                                    @foreach (var time in new[] { 5, 15, 30, 45 })
                                    {
                                        <div class="col-3">
                                            <input type="radio" class="btn-check" name="timeOptions" id="time-@time"
                                                   value="@time" checked="@(selectedMinutes == time)"
                                                   @onclick="() => selectedMinutes = time">
                                                <label class="btn w-100" for="time-@time">
                                                    <span class="fs-5">@time</span>
                                                    <span style="font-size: 0.6rem; opacity: 0.7;">PHÚT</span>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="d-flex align-items-center p-3 rounded-3 bg-light mb-4">
                                    <i class="bi bi-clock-history text-primary me-3 fs-4"></i>
                                    <div style="font-size: 0.85rem;" class="text-secondary">
                                        Tổng cộng <strong>@selectedCount câu hỏi</strong> trong <strong>@selectedMinutes phút</strong>. Sẵn sàng?
                                    </div>
                                </div>

                                <button class="btn btn-start btn-lg w-100 shadow-lg text-uppercase" @onclick="StartPractice">
                                    Bắt đầu thử thách
                                    <i class="bi bi-rocket-takeoff-fill ms-2"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

@code {
    private List<CategoryDto>? categories;
    private int selectedCategoryId = 0;
    private int selectedCount = 20;
    private int selectedMinutes = 15;

    // Các biến hứng thông tin người dùng
    private string fullName = "";
    private string studentId = "";
    private string className = "";
    private bool showValidationError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/Categories");
            if (categories != null)
            {
                categories = categories
                    .Where(c => !c.CategoryName.Equals("Tuyên truyền", StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }
        }
        catch { /* Xử lý lỗi nếu cần */ }
    }

    private async Task StartPractice()
    {
        // Kiểm tra hợp lệ: Bắt buộc nhập Họ và Tên
        if (string.IsNullOrWhiteSpace(fullName))
        {
            showValidationError = true;
            return;
        }
        showValidationError = false;

        // Lưu thông tin vào SessionStorage
        await JS.InvokeVoidAsync("sessionStorage.setItem", "p_fullName", fullName.Trim());
        await JS.InvokeVoidAsync("sessionStorage.setItem", "p_studentId", string.IsNullOrWhiteSpace(studentId) ? "N/A" : studentId.Trim());
        await JS.InvokeVoidAsync("sessionStorage.setItem", "p_className", string.IsNullOrWhiteSpace(className) ? "N/A" : className.Trim());

        // Điều hướng sang trang làm bài
        NavManager.NavigateTo($"/practice/{selectedCategoryId}/{selectedCount}/{selectedMinutes}");
    }

    public class CategoryDto
    {
        public int CategoryId { get; set; }
        public string CategoryName { get; set; } = "";
    }
}