﻿
@page "/join/{sessionCode}"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using System.Timers
@using System.Text.Json
@implements IDisposable
@inject QuizService QuizService
@inject IJSRuntime JS

<PageTitle>Phòng Thi - Khoa NV4</PageTitle>

<div class="container py-5" style="max-width: 800px;">

    @* TRẠNG THÁI 1: ĐANG TẢI DỮ LIỆU PHIÊN THI *@
    @if (isLoadingSession)
    {
        <div class="text-center py-5 mt-5">
            <div class="spinner-border text-danger" style="width: 4rem; height: 4rem;" role="status"></div>
            <h4 class="mt-4 fw-bold text-muted text-uppercase">Đang kết nối vào phòng thi...</h4>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden text-center mt-5">
            <div class="bg-danger text-white py-4">
                <i class="oi oi-warning" style="font-size: 3rem;"></i>
                <h3 class="fw-bold mt-2 text-uppercase">Không thể truy cập</h3>
            </div>
            <div class="card-body p-5">
                <p class="fs-5 text-dark mb-4">@errorMessage</p>
                <a href="/" class="btn btn-outline-danger px-5 py-2 fw-bold rounded-pill">Quay lại Trang Chủ</a>
            </div>
        </div>
    }
    @* TRẠNG THÁI 2: MÀN HÌNH CHỜ (NHẬP THÔNG TIN) *@
    else if (CurrentState == QuizState.Setup)
    {
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="bg-dark text-white text-center py-4">
                <h2 class="fw-bold mb-0 text-uppercase">HỆ THỐNG KIỂM TRA KIẾN THỨC</h2>
            </div>
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <img src="/Images/Logo_hoc_vien_ANND.png" alt="Logo" style="height: 100px;" class="mb-3" />
                    <h4 class="fw-bold" style="color: #1a237e;">@sessionName</h4>
                    <p class="text-muted">Mã phòng thi: <strong class="text-danger">@sessionCode</strong></p>
                </div>

                <div class="alert alert-warning border-0 bg-light-warning mb-4">
                    <i class="oi oi-info me-2 text-warning"></i>
                    <strong>Nội quy:</strong> Bài thi gồm <strong>@questionCount câu hỏi</strong>, thời gian làm bài là <strong>@timeLimitMinutes phút</strong>. Hết giờ hệ thống sẽ tự động thu bài.
                </div>

                <div class="bg-light p-4 rounded-3 border">
                    <h5 class="fw-bold text-center mb-3">ĐIỀN THÔNG TIN THÍ SINH</h5>

                    @if (!string.IsNullOrEmpty(validationError))
                    {
                        <div class="alert alert-danger py-2 small text-center">@validationError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và Tên *</label>
                        <input type="text" class="form-control fw-bold text-primary" @bind="studentName" placeholder="VD: Nguyễn Văn A" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mã Sinh Viên / Email *</label>
                            <input type="text" class="form-control fw-bold" @bind="studentId" placeholder="VD: B21DCCN123" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Lớp *</label>
                            <input type="text" class="form-control fw-bold" @bind="studentClass" placeholder="VD: B21CQCN01-B" />
                        </div>
                    </div>
                </div>

                <button class="btn btn-danger btn-lg w-100 fw-bold py-3 mt-4 shadow" @onclick="StartQuiz" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>ĐANG TẢO BÀI THI...</span>
                    }
                    else
                    {
                        <span><i class="oi oi-media-play me-2"></i> BẮT ĐẦU LÀM BÀI</span>
                    }
                </button>
            </div>
        </div>
    }

    @* TRẠNG THÁI 3: ĐANG LÀM BÀI THI *@
    else if (CurrentState == QuizState.Playing && questions != null && questions.Any())
    {
        var currentQ = questions[currentQuestionIndex];

        @* HEADER THANH TRẠNG THÁI *@
        <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-3 shadow-sm border-start border-danger border-4 sticky-top" style="top: 10px; z-index: 100;">
            <div>
                <h5 class="fw-bold m-0" style="color: #1a237e;">Câu hỏi @(currentQuestionIndex + 1) / @questions.Count</h5>
                <small class="text-muted">Thí sinh: <strong>@studentName</strong> (@studentClass)</small>
            </div>
            <div class="fw-bold fs-3 @(timeLeftSeconds <= 60 ? "text-danger animate-blink" : "text-dark") bg-light px-3 py-1 rounded-3 border">
                <i class="oi oi-clock me-1"></i> @GetFormattedTime()
            </div>
        </div>

        @* NỘI DUNG CÂU HỎI *@
        <div class="card shadow border-0 rounded-4 mb-4">
            <div class="card-body p-4 p-md-5">
                <h4 class="fw-bold lh-base mb-4 text-dark">@currentQ.GetProperty("content").GetString()</h4>

                <div class="d-flex flex-column gap-3">
                    @{
                        int qId = currentQ.GetProperty("questionId").GetInt32();
                    }
                    <button class="btn @GetOptionClass(qId, "A") text-start p-3 fw-semibold fs-5 rounded-3" @onclick='() => SelectAnswer(qId, "A")'>
                        <span class="badge bg-white text-dark me-2">A</span> @currentQ.GetProperty("optionA").GetString()
                    </button>
                    <button class="btn @GetOptionClass(qId, "B") text-start p-3 fw-semibold fs-5 rounded-3" @onclick='() => SelectAnswer(qId, "B")'>
                        <span class="badge bg-white text-dark me-2">B</span> @currentQ.GetProperty("optionB").GetString()
                    </button>
                    <button class="btn @GetOptionClass(qId, "C") text-start p-3 fw-semibold fs-5 rounded-3" @onclick='() => SelectAnswer(qId, "C")'>
                        <span class="badge bg-white text-dark me-2">C</span> @currentQ.GetProperty("optionC").GetString()
                    </button>
                    <button class="btn @GetOptionClass(qId, "D") text-start p-3 fw-semibold fs-5 rounded-3" @onclick='() => SelectAnswer(qId, "D")'>
                        <span class="badge bg-white text-dark me-2">D</span> @currentQ.GetProperty("optionD").GetString()
                    </button>
                </div>
            </div>
        </div>

        @* THANH ĐIỀU HƯỚNG *@
        <div class="d-flex justify-content-between mb-5">
            <button class="btn btn-secondary px-4 fw-bold" @onclick="PrevQuestion" disabled="@(currentQuestionIndex == 0)">
                <i class="oi oi-arrow-thick-left me-1"></i> Câu trước
            </button>

            @if (currentQuestionIndex < questions.Count - 1)
            {
                <button class="btn btn-primary px-4 fw-bold shadow-sm" @onclick="NextQuestion">
                    Câu tiếp theo <i class="oi oi-arrow-thick-right ms-1"></i>
                </button>
            }
            else
            {
                <button class="btn btn-danger px-5 fw-bold shadow" @onclick="ConfirmSubmit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="oi oi-check me-1"></i> NỘP BÀI NGAY
                </button>
            }
        </div>
    }

    @* TRẠNG THÁI 4: KẾT QUẢ BÀI THI *@
    else if (CurrentState == QuizState.Finished && result != null)
    {
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden text-center mt-4">
            <div class="bg-success text-white py-4">
                <i class="oi oi-circle-check" style="font-size: 4rem;"></i>
                <h2 class="fw-bold mt-2 text-uppercase">NỘP BÀI THÀNH CÔNG</h2>
            </div>
            <div class="card-body p-5">
                <h5 class="text-muted mb-2">Thí sinh: <strong>@studentName</strong></h5>
                <h5 class="text-muted mb-4">Lớp: <strong>@studentClass</strong></h5>

                <div class="p-4 bg-light rounded-4 border mb-4">
                    <h4 class="text-secondary mb-3">Kết quả của bạn:</h4>
                    <div class="display-1 fw-bold text-danger mb-2">
                        @result.CorrectAnswers <span class="text-muted fs-3">/ @result.TotalQuestions</span>
                    </div>
                </div>

                <h5 class="mb-5" style="color: #2c3e50;">
                    @if (result.CorrectAnswers == result.TotalQuestions)
                    {
                        <span>🏆 Xuất sắc! Bạn nắm kiến thức tuyệt đối!</span>
                    }
                    else if (result.CorrectAnswers >= result.TotalQuestions * 0.7)
                    {
                        <span>👍 Rất tốt! Kiến thức của bạn khá vững.</span>
                    }
                    else
                    {
                        <span>📚 Cần cố gắng hơn! Hãy ôn tập lại tài liệu nhé.</span>
                    }
                </h5>

                <a href="/" class="btn btn-outline-danger px-5 py-2 fw-bold rounded-pill">VỀ TRANG CHỦ</a>
            </div>
        </div>
    }
</div>

<style>
    .bg-light-warning {
        background-color: #fff8e1;
    }

    .animate-blink {
        animation: blinker 1s linear infinite;
    }

    @@keyframes blinker {
        50% {
            opacity: 0;
        }
    }

    .btn-outline-dark:hover {
        background-color: #f8f9fa;
        color: #000;
    }

    .btn-selected {
        background-color: #e3f2fd;
        border: 2px solid #0d6efd !important;
        color: #0d6efd;
    }
</style>

@code {
    [Parameter]
    public string sessionCode { get; set; } = "";

    private enum QuizState { Setup, Playing, Finished }
    private QuizState CurrentState = QuizState.Setup;

    // Biến lưu thông tin Phiên thi
    private bool isLoadingSession = true;
    private string errorMessage = "";
    private int sessionId = 0;
    private int sessionCategoryId = 0;
    private string sessionName = "";
    private int questionCount = 0;
    private int timeLimitMinutes = 0;

    // Biến lưu thông tin Thí sinh
    private string studentName = "";
    private string studentId = "";
    private string studentClass = "";
    private string validationError = "";

    private List<JsonElement>? questions;
    private int currentQuestionIndex = 0;
    private Dictionary<int, string> userAnswers = new();

    private bool isLoading = false;
    private bool isSubmitting = false;
    private QuizResultDto? result;

    // --- LOGIC ĐỒNG HỒ ĐẾM NGƯỢC ---
    private Timer? timer;
    private int timeLeftSeconds = 0;

    protected override async Task OnInitializedAsync()
    {
        await ConnectToSession();
    }

    private async Task ConnectToSession()
    {
        isLoadingSession = true;
        errorMessage = "";

        try
        {
            var sessionData = await QuizService.JoinSessionAsync(sessionCode);
            if (sessionData != null && sessionData.HasValue)
            {
                var sessionInfo = sessionData.Value.GetProperty("session");

                sessionId = sessionInfo.GetProperty("sessionId").GetInt32();
                sessionName = sessionInfo.GetProperty("sessionName").GetString() ?? "";
                questionCount = sessionInfo.GetProperty("questionCount").GetInt32();
                timeLimitMinutes = sessionInfo.GetProperty("timeLimitMinutes").GetInt32();

                // Bắt cẩn thận thuộc tính CategoryId vì nó có thể Null
                if (sessionInfo.TryGetProperty("categoryId", out var catProp) && catProp.ValueKind != JsonValueKind.Null)
                {
                    sessionCategoryId = catProp.GetInt32();
                }

                // Lấy mảng câu hỏi
                var questionsArray = sessionData.Value.GetProperty("questions");
                questions = questionsArray.EnumerateArray().ToList();

                // Lấy lại Tên SV đã nhớ trong LocalStorage (nếu có)
                var savedName = await JS.InvokeAsync<string>("localStorage.getItem", "quiz_name");
                var savedId = await JS.InvokeAsync<string>("localStorage.getItem", "quiz_id");
                var savedClass = await JS.InvokeAsync<string>("localStorage.getItem", "quiz_class");

                if (!string.IsNullOrEmpty(savedName)) studentName = savedName;
                if (!string.IsNullOrEmpty(savedId)) studentId = savedId;
                if (!string.IsNullOrEmpty(savedClass)) studentClass = savedClass;
            }
        }
        catch (Exception ex)
        {
            // Lỗi khi phiên bị khóa hoặc mã sai
            errorMessage = ex.Message.Replace("\"", "");
        }
        finally
        {
            isLoadingSession = false;
        }
    }

    private async Task StartQuiz()
    {
        validationError = "";

        if (string.IsNullOrWhiteSpace(studentName) || string.IsNullOrWhiteSpace(studentId) || string.IsNullOrWhiteSpace(studentClass))
        {
            validationError = "Vui lòng nhập đầy đủ Họ Tên, Mã SV và Lớp để bắt đầu thi.";
            return;
        }

        isLoading = true;

        // Ghi nhớ thông tin Thí sinh vào LocalStorage cho lần thi sau
        await JS.InvokeVoidAsync("localStorage.setItem", "quiz_name", studentName.Trim());
        await JS.InvokeVoidAsync("localStorage.setItem", "quiz_id", studentId.Trim());
        await JS.InvokeVoidAsync("localStorage.setItem", "quiz_class", studentClass.Trim());

        // Bắt đầu thi
        userAnswers.Clear();
        currentQuestionIndex = 0;
        timeLeftSeconds = timeLimitMinutes * 60;

        CurrentState = QuizState.Playing;

        // Khởi động đồng hồ
        timer = new Timer(1000);
        timer.Elapsed += CountDownTimer;
        timer.Start();

        isLoading = false;
    }

    private void CountDownTimer(Object? source, ElapsedEventArgs e)
    {
        if (timeLeftSeconds > 0)
        {
            timeLeftSeconds--;
            InvokeAsync(StateHasChanged);
        }
        else
        {
            timer?.Stop();
            InvokeAsync(SubmitQuiz); // Hết giờ nộp tự động
        }
    }

    private string GetFormattedTime()
    {
        int minutes = timeLeftSeconds / 60;
        int seconds = timeLeftSeconds % 60;
        return $"{minutes:D2}:{seconds:D2}";
    }

    private void SelectAnswer(int questionId, string option)
    {
        userAnswers[questionId] = option;
    }

    private string GetOptionClass(int questionId, string option)
    {
        if (userAnswers.ContainsKey(questionId) && userAnswers[questionId] == option)
        {
            return "btn-selected";
        }
        return "btn-outline-dark border-1 text-dark";
    }

    private void NextQuestion()
    {
        if (currentQuestionIndex < questions!.Count - 1) currentQuestionIndex++;
    }

    private void PrevQuestion()
    {
        if (currentQuestionIndex > 0) currentQuestionIndex--;
    }

    private async Task ConfirmSubmit()
    {
        int answeredCount = userAnswers.Count;
        if (answeredCount < questions!.Count)
        {
            bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn mới làm được {answeredCount}/{questions.Count} câu. Vẫn còn câu chưa đánh. Bạn có thực sự muốn nộp bài sớm không?");
            if (!confirmed) return;
        }
        await SubmitQuiz();
    }

    private async Task SubmitQuiz()
    {
        isSubmitting = true;
        timer?.Stop();

        try
        {
            var request = new SubmitQuizRequest
                {
                    SessionId = sessionId,
                    CategoryId = sessionCategoryId,
                    FullName = studentName.Trim(),
                    StudentIdOrEmail = studentId.Trim(),
                    ClassName = studentClass.Trim(),
                    Answers = userAnswers
                };

            result = await QuizService.SubmitQuizAsync(request);
            if (result != null) CurrentState = QuizState.Finished;
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "Đã có lỗi xảy ra trong quá trình nộp bài. Vui lòng báo cho Admin.");
        }
        finally { isSubmitting = false; }
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}