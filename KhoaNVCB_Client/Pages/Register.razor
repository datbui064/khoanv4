@page "/register"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Đăng ký tài khoản - Khoa NV4</PageTitle>

<div class="auth-page-wrapper">
    <div class="register-box-container">

        @* Cột trái: Thông tin hướng dẫn *@
        <div class="register-info-side d-none d-lg-flex">
            <div class="info-content text-white">
                <div class="info-badge">Hệ thống Nội bộ</div>
                <h2 class="fw-bold mt-3">Gia nhập đội ngũ</h2>
                <p class="opacity-75">Tạo tài khoản để truy cập kho tài liệu nghiệp vụ và các bản tin an ninh mới nhất.</p>

                <div class="benefit-list mt-4">
                    <div class="benefit-item">
                        <i class="fa-solid fa-circle-check text-gold me-2"></i>
                        <span>Tài liệu chuyên sâu</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fa-solid fa-circle-check text-gold me-2"></i>
                        <span>Thông báo tin tức 24/7</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fa-solid fa-circle-check text-gold me-2"></i>
                        <span>Kết nối giảng viên</span>
                    </div>
                </div>

                <div class="register-footer-logo mt-5">
                    <img src="/Images/Logo_hoc_vien_ANND.png" alt="Logo" style="width: 60px; filter: brightness(0) invert(1);">
                </div>
            </div>
        </div>

        @* Cột phải: Form Đăng ký *@
        <div class="register-form-side p-4 p-md-5">
            <div class="form-header mb-4">
                <h3 class="fw-800 text-navy mb-1">ĐĂNG KÝ TÀI KHOẢN</h3>
                <p class="text-muted small">Vui lòng điền đầy đủ thông tin để khởi tạo tài khoản.</p>
            </div>

            <div class="row">
                @* Họ tên *@
                <div class="col-md-12 mb-3">
                    <label class="form-label-custom">Họ và tên <span class="text-danger">*</span></label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-id-card icon-field"></i>
                        <input class="form-control-custom" @bind="registerModel.FullName" placeholder="Nhập tên đầy đủ..." />
                    </div>
                </div>

                @* Email *@
                <div class="col-md-12 mb-3">
                    <label class="form-label-custom">Địa chỉ Email</label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-envelope icon-field"></i>
                        <input type="email" class="form-control-custom" @bind="registerModel.Email" placeholder="vidu@hvannd.edu.vn" />
                    </div>
                </div>

                @* Tên đăng nhập *@
                <div class="col-md-12 mb-3">
                    <label class="form-label-custom">Tên đăng nhập <span class="text-danger">*</span></label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-user-tag icon-field"></i>
                        <input class="form-control-custom" @bind="registerModel.Username" placeholder="Ví dụ: nguyenvanan123" />
                    </div>
                </div>

                @* Mật khẩu *@
                <div class="col-md-12 mb-4">
                    <label class="form-label-custom">Mật khẩu <span class="text-danger">*</span></label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-key icon-field"></i>
                        <input type="password" class="form-control-custom" @bind="registerModel.Password" placeholder="••••••••" />
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-modern error mb-4">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @errorMessage
                </div>
            }

            @if (isSuccess)
            {
                <div class="alert-modern success mb-4">
                    <i class="fa-solid fa-circle-check me-2"></i> Đăng ký thành công! Đang chuyển hướng...
                </div>
            }

            <button class="btn-register-gold w-100 mb-4" @onclick="HandleRegister" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span> <span>ĐANG KHỞI TẠO...</span>
                }
                else
                {
                    <span>HOÀN TẤT ĐĂNG KÝ <i class="fa-solid fa-paper-plane ms-2"></i></span>
                }
            </button>

            <div class="text-center">
                <p class="text-muted small">
                    Đã có tài khoản?
                    <a href="/login" class="link-gold fw-bold text-decoration-none ms-1">Đăng nhập tại đây</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private string? errorMessage;
    private bool isProcessing = false;
    private bool isSuccess = false;

    private async Task HandleRegister()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(registerModel.FullName) ||
            string.IsNullOrWhiteSpace(registerModel.Username) ||
            string.IsNullOrWhiteSpace(registerModel.Password))
        {
            errorMessage = "Vui lòng điền đầy đủ các thông tin bắt buộc (*).";
            return;
        }

        isProcessing = true;

        var success = await AuthService.Register(registerModel);
        if (success)
        {
            isSuccess = true;
            StateHasChanged();
            await Task.Delay(2000); // Đợi 2 giây cho người dùng đọc thông báo
            Nav.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Đăng ký thất bại. Tên đăng nhập này có thể đã tồn tại!";
        }
        isProcessing = false;
    }
}
<style>
    /* Kế thừa các biến màu từ Login */
    :root {
        --navy-deep: #0a192f;
        --gold-primary: #c5a059;
    }

    .auth-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #050c18 0%, #112240 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .register-box-container {
        width: 100%;
        max-width: 950px;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 25px 50px rgba(0,0,0,0.4);
    }

    /* Cột trái (Thông tin) */
    .register-info-side {
        width: 40%;
        background: var(--navy-deep);
        padding: 50px;
        position: relative;
        border-right: 4px solid var(--gold-primary);
        display: flex;
        align-items: center;
    }

    .info-badge {
        display: inline-block;
        padding: 5px 15px;
        background: rgba(197, 160, 89, 0.2);
        color: var(--gold-primary);
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .benefit-item {
        margin-bottom: 15px;
        font-size: 0.9rem;
    }

    /* Form Styles */
    .register-form-side {
        flex: 1;
        background: #fff;
    }

    .input-group-custom {
        position: relative;
    }

    .icon-field {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        transition: 0.3s;
    }

    .form-control-custom {
        width: 100%;
        padding: 12px 15px 12px 45px; /* Chừa chỗ cho icon */
        border: 1px solid #eee;
        border-radius: 10px;
        background: #fdfdfd;
        font-size: 0.9rem;
    }

        .form-control-custom:focus {
            border-color: var(--gold-primary);
            box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
            outline: none;
        }

            .form-control-custom:focus + .icon-field {
                color: var(--gold-primary);
            }

    /* Alert Nâng Cấp */
    .alert-modern {
        padding: 12px 15px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 500;
    }

        .alert-modern.error {
            background: #fff1f0;
            border-left: 4px solid #f5222d;
            color: #cf1322;
        }

        .alert-modern.success {
            background: #f6ffed;
            border-left: 4px solid #52c41a;
            color: #389e0d;
        }

    /* Button */
    .btn-register-gold {
        background: var(--gold-primary);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 10px;
        font-weight: 800;
        transition: 0.3s;
    }

        .btn-register-gold:hover {
            background: #b08d4a;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(197, 160, 89, 0.3);
        }

    @@media (max-width: 991px) {
        .register-box-container

    {
        max-width: 500px;
    }

    }</style>