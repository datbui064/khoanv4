@page "/register"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Đăng ký tài khoản - Khoa NV3</PageTitle>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5 shadow-sm p-4 bg-white rounded border-top border-danger border-4">
            <h3 class="text-center mb-4 fw-bold" style="color: #1a237e;">ĐĂNG KÝ TÀI KHOẢN</h3>

            <div class="mb-3">
                <label class="form-label fw-bold">Họ và tên hiển thị <span class="text-danger">*</span></label>
                <input class="form-control" @bind="registerModel.FullName" placeholder="Nhập tên thật của bạn..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input type="email" class="form-control" @bind="registerModel.Email" placeholder="Nhập địa chỉ email..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                <input class="form-control" @bind="registerModel.Username" placeholder="Nhập tên tài khoản..." />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                <input type="password" class="form-control" @bind="registerModel.Password" placeholder="Nhập mật khẩu..." />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2">@errorMessage</div>
            }

            @if (isSuccess)
            {
                <div class="alert alert-success py-2">Đăng ký thành công! Đang chuyển hướng đến trang đăng nhập...</div>
            }

            <button class="btn btn-danger w-100 fw-bold mb-3" @onclick="HandleRegister" disabled="@isProcessing">
                @(isProcessing ? "Đang xử lý..." : "ĐĂNG KÝ NGAY")
            </button>

            <div class="text-center text-muted small">
                Đã có tài khoản? <a href="/login" class="text-primary text-decoration-none fw-bold">Đăng nhập tại đây</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private string? errorMessage;
    private bool isProcessing = false;
    private bool isSuccess = false;

    private async Task HandleRegister()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(registerModel.FullName) ||
            string.IsNullOrWhiteSpace(registerModel.Username) ||
            string.IsNullOrWhiteSpace(registerModel.Password))
        {
            errorMessage = "Vui lòng điền đầy đủ các thông tin bắt buộc (*).";
            return;
        }

        isProcessing = true;

        var success = await AuthService.Register(registerModel);
        if (success)
        {
            isSuccess = true;
            StateHasChanged();
            await Task.Delay(2000); // Đợi 2 giây cho người dùng đọc thông báo
            Nav.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Đăng ký thất bại. Tên đăng nhập này có thể đã tồn tại!";
        }
        isProcessing = false;
    }
}