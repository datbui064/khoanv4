@page "/tuyen-truyen"
@using KhoaNVCB_Client.Models
@using KhoaNVCB_Client.Services
@attribute [Authorize]
@inject PostService PostService
@inject NavigationManager Nav

<PageTitle>Tuyên truyền - Khoa NV4</PageTitle>

<div class="container py-5 mt-4">
    @* --- TIÊU ĐỀ TRANG --- *@
    <div class="header-section mb-4">
        <h2 class="fw-bold text-uppercase text-navy border-start border-danger border-4 ps-3">Các bài viết tuyên truyền</h2>
       
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive" style="min-height: 400px;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase" style="font-size: 0.85rem;">
                        <tr>
                            <th class="ps-4" style="width: 120px;">Hình ảnh</th>
                            <th>Nội dung bài viết</th>
                            <th class="d-none d-md-table-cell" style="width: 180px;">Ngày đăng</th>
                            <th class="text-end pe-4" style="width: 120px;">Xem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (allPosts == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status"></div>
                                    <p class="mt-2 mb-0">Đang tải dữ liệu...</p>
                                </td>
                            </tr>
                        }
                        else if (!allPosts.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="alert alert-info d-inline-block">Hiện chưa có bài viết nào được xuất bản.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var post in allPosts)
                            {
                                <tr class="post-row" style="cursor: pointer;" @onclick='() => Nav.NavigateTo("/post/" + post.PostId)'>
                                    <td class="ps-4">
                                        <div class="img-wrapper">
                                            <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "images/Logo_hoc_vien_ANND.png" : post.ImageUrl)"
                                                 class="rounded shadow-sm img-fluid"
                                                 alt="@post.Title"
                                                 onerror="this.src='/images/no-image-available.png';" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-navy mb-1 post-title-link">@post.Title</div>
                                        <div class="small text-muted text-truncate-2" style="max-width: 600px;">
                                            @post.Summary
                                        </div>
                                    </td>
                                    <td class="d-none d-md-table-cell">
                                        <span class="text-muted small">
                                            <i class="bi bi-calendar3 me-1"></i> @post.CreatedDate?.ToString("##/##/####")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/post/@post.PostId" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Biến màu sắc */
    :root {
        --navy-blue: #1a237e;
        --gold-text: #c5a059;
    }

    .text-navy { color: var(--navy-blue); }
    
    /* Hiệu ứng bảng */
    .table thead th {
        font-weight: 700;
        color: #4a5568;
        padding: 1.2rem 0.75rem;
        border-bottom: 2px solid #dee2e6;
    }

    .post-row {
        transition: all 0.2s ease;
    }

    .post-row:hover {
        background-color: rgba(26, 35, 126, 0.04) !important;
    }

    /* Ảnh xem trước */
    .img-wrapper {
        width: 80px;
        height: 55px;
        overflow: hidden;
        border-radius: 6px;
    }

    .img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .post-row:hover .img-wrapper img {
        transform: scale(1.1);
    }

    /* Text link hiệu ứng */
    .post-title-link {
        font-size: 1.05rem;
        transition: color 0.2s;
    }

    .post-row:hover .post-title-link {
        color: #dc3545 !important;
    }

    /* Cắt dòng cho summary */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Tùy chỉnh thanh cuộn cho mobile */
    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }
    .table-responsive::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }
</style>

@code {
    private List<PostDto>? allPosts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await PostService.GetAllAsync();
            if (data != null)
            {
                allPosts = data
                    .Where(p => p.Status == "Published" &&
                           p.CategoryName != null &&
                           p.CategoryName.Equals("Tuyên Truyền", StringComparison.OrdinalIgnoreCase))
                    .OrderByDescending(p => p.CreatedDate)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}